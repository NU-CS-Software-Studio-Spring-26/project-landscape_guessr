<% content_for :title, "Profile" %>

<div class="w-full max-w-xl mx-auto space-y-6 py-6">
  <div>
    <h1 class="text-3xl font-bold"><%= @user.username %></h1>
    <p class="text-sm text-gray-500 mt-1"><%= @user.email_address %></p>
  </div>

  <%# Stats %>
  <section class="space-y-3">
    <h2 class="text-lg font-semibold text-gray-700">Stats</h2>
    <div class="grid grid-cols-3 gap-3">
      <div class="rounded-lg border border-gray-200 px-4 py-3 text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Games played</p>
        <p class="text-2xl font-bold text-gray-800 mt-1"><%= @games_played %></p>
      </div>
      <div class="rounded-lg border border-gray-200 px-4 py-3 text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Best score</p>
        <p class="text-2xl font-bold text-blue-600 mt-1"><%= @best_score ? number_with_delimiter(@best_score) : "—" %></p>
      </div>
      <div class="rounded-lg border border-gray-200 px-4 py-3 text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Avg score</p>
        <p class="text-2xl font-bold text-gray-800 mt-1"><%= @avg_score ? number_with_delimiter(@avg_score) : "—" %></p>
      </div>
    </div>
  </section>

  <%# Account %>
  <section class="space-y-3 pt-4 border-t border-gray-200">
    <h2 class="text-lg font-semibold text-gray-700">Account</h2>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Reset password", new_password_path,
            class: "rounded-md px-3 py-2 bg-gray-100 hover:bg-gray-50 text-sm font-medium border border-gray-200" %>
      <%= button_to "Sign out", session_path, method: :delete,
            class: "rounded-md px-3 py-2 bg-gray-100 hover:bg-gray-50 text-sm font-medium border border-gray-200 cursor-pointer" %>
    </div>
  </section>
</div>
