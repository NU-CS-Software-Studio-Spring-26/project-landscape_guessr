<% content_for :title, "Games" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="heading-page">Games</h1>
    <div class="flex space-x-2">
      <%= link_to "Leaderboard", leaderboard_games_path, class: "btn-secondary" %>
      <%= button_to "New game", games_path, method: :post, data: { turbo: false }, class: "btn-primary" %>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-2 mt-6 mb-4 text-sm">
    <% [["All", "all"], ["In progress", "in_progress"], ["Completed", "completed"]].each do |label, value| %>
      <%= link_to label, games_path(status: value, sort: @sort, direction: @direction),
            class: "rounded-full px-3 py-1 text-xs font-medium #{@status == value ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200"}" %>
    <% end %>

    <div class="ml-auto flex items-center gap-2">
      <label for="sort_dir" class="muted">Sort by</label>
      <%= select_tag :sort_dir,
            options_for_select(
              [
                ["Newest first",  games_path(status: @status, sort: "created_at", direction: "desc")],
                ["Oldest first",  games_path(status: @status, sort: "created_at", direction: "asc")],
                ["Highest score", games_path(status: @status, sort: "score",      direction: "desc")],
                ["Lowest score",  games_path(status: @status, sort: "score",      direction: "asc")]
              ],
              games_path(status: @status, sort: @sort, direction: @direction)
            ),
            onchange: "window.location = this.value",
            class: "rounded-md border border-gray-300 px-3 py-1.5 text-sm cursor-pointer" %>
    </div>
  </div>

  <div id="games" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @games.any? %>
      <% @games.each do |game| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render game %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", game, class: "btn-secondary w-full sm:w-auto" %>
            <% if admin? %>
              <%= link_to "Edit", edit_game_path(game), class: "btn-secondary w-full sm:w-auto" %>
            <% end %>
            <%= button_to "Destroy", game, method: :delete,
                  data: { turbo_confirm: "Are you sure?" },
                  class: "btn-danger w-full sm:w-auto" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10 text-gray-500">
        <% case @status %>
        <% when "completed" %>
          No completed games yet — click "New game" to play your first.
        <% when "in_progress" %>
          No games in progress.
        <% else %>
          You haven't started any games yet — click "New game" to play your first.
        <% end %>
      </p>
    <% end %>
  </div>
</div>
