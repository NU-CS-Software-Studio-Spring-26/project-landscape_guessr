<% content_for :title, "Game ##{@game.id}" %>
<% content_for :head do %>
  <%= render "shared/maplibre_assets" %>
<% end %>

<div class="w-full space-y-4">
  <div class="flex justify-between items-center">
    <h1 class="heading-page">
      <% if @image %>
        Round <%= @round %> / <%= @total_rounds %>
      <% else %>
        Game complete
      <% end %>
    </h1>
    <%= link_to "Back to games", games_path, class: "btn-secondary text-sm py-2" %>
  </div>

  <% if @image %>
    <div data-controller="game"
         data-action="guess-map:pinned->game#pinChanged"
         data-game-game-path-value="<%= game_path(@game) %>"
         class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <img src="<%= image_src(@image, width: 800) %>" alt="Guess this location"
             class="w-full h-[60vh] object-cover rounded-md border border-gray-200">
      </div>
      <div class="space-y-3">
        <%= render "shared/guess_map" %>
        <%= form_with url: guesses_path, local: true, class: "flex items-center gap-2" do |f| %>
          <%= hidden_field_tag "guess[game_id]", @game.id %>
          <%= hidden_field_tag "guess[image_id]", @image.id %>
          <%= hidden_field_tag "guess[latitude]", "", data: { game_target: "latitude" } %>
          <%= hidden_field_tag "guess[longitude]", "", data: { game_target: "longitude" } %>
          <span data-game-target="readout" class="text-sm text-gray-600">Click the map to drop a pin.</span>
          <p data-game-target="result" class="text-lg font-medium"></p>
          <%= submit_tag "Submit guess", data: { game_target: "submit", action: "game#submitGuess" }, disabled: true,
              class: "btn-primary ml-auto disabled:opacity-40" %>
          <button type="button" data-game-target="next" data-action="game#nextRound"
                  class="btn-primary hidden ml-auto">
            Next round
          </button>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
