# Copy to .env and fill in values (dotenv-rails loads .env in development/test).

# Google OAuth (optional — password sign-in works without these)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# AI practice hints via Gemini AND AI-generated image sets — same key.
# Hints: set both GEMINI_API_KEY and AI_HINTS_ENABLED.
# AI image sets: only needs GEMINI_API_KEY (always enabled when the key is present).
# GEMINI_API_KEY=          # from https://aistudio.google.com/apikey (not OAuth client credentials)
# GEMINI_MODEL=gemini-2.5-flash-lite
# AI_HINTS_ENABLED=1       # set to 1 to enable when GEMINI_API_KEY is set

# Production-only — outbound email (used for signup verification). Without
# these, signups still succeed but verification emails fail to send. Users
# can resend from the banner in the layout.
# GMAIL_USERNAME=
# GMAIL_APP_PASSWORD=

# Production-only — S3 image uploads. aws-sdk-s3 reads these directly from ENV.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
