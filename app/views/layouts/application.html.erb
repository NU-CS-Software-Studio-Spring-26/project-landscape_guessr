<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Project Landscape Guessr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Project Landscape Guessr">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav aria-label="Primary" class="container mx-auto px-5 pt-5 flex justify-between items-center text-sm">
      <div class="flex items-center gap-5">
        <%= link_to "Landscape Guessr", root_path, class: "font-bold" %>

        <%# Dropdown nav menu %>
        <div data-controller="dropdown" data-action="keydown->dropdown#keydown" class="relative">
          <button data-dropdown-target="trigger"
                  data-action="click->dropdown#toggle"
                  class="flex items-center gap-1 text-gray-700 hover:text-blue-600 font-medium cursor-pointer">
            Menu
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div data-dropdown-target="menu" class="hidden absolute left-0 mt-2 w-52 bg-white border border-gray-200 rounded-lg shadow-lg py-2 z-50">
            <% if authenticated? %>
              <div class="px-3 pb-2 border-b border-gray-100">
                <%= button_to "Start new game", games_path, method: :post,
                      role: "menuitem",
                      class: "btn-primary w-full text-sm py-1.5 mt-1" %>
              </div>
              <div class="pt-2 flex flex-col gap-0.5 px-2">
                <%= link_to "Previous games", games_path,     role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
                <%= link_to "Practice",       practice_path,  role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
                <%= link_to "Image Sets",     image_sets_path, role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
                <%= link_to "Leaderboard",    leaderboard_games_path, role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
              </div>
            <% else %>
              <div class="flex flex-col gap-0.5 px-2 py-1">
                <%= link_to "Sign up to play", new_registration_path, role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
                <%= link_to "Sign in",         new_session_path,      role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
                <%= link_to "Practice mode",   practice_path,         role: "menuitem", class: "block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-600 font-medium" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <% if authenticated? %>
          <%= link_to Current.user.username, profile_path, class: "text-gray-700 hover:text-blue-600 font-medium hidden sm:inline" %>
          <%= button_to "Sign out", session_path, method: :delete, class: "btn-secondary text-sm py-1.5" %>
        <% else %>
          <%= link_to "Sign in", new_session_path, class: "btn-secondary text-sm py-1.5" %>
          <%= link_to "Sign up", new_registration_path, class: "btn-primary text-sm py-1.5" %>
        <% end %>
      </div>
    </nav>

    <main aria-label="Main content" class="container mx-auto mt-20 px-5">
      <% if notice = flash[:notice] %>
        <p class="py-2 px-3 mb-5 bg-green-50 text-green-600 font-medium rounded-md mx-auto md:w-2/3 w-full" id="notice"><%= notice %></p>
      <% end %>
      <% if alert = flash[:alert] %>
        <p class="py-2 px-3 mb-5 bg-red-50 text-red-600 font-medium rounded-md mx-auto md:w-2/3 w-full" id="alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>

    <footer aria-label="Site" class="container mx-auto px-5 py-8 mt-12 border-t border-gray-200 text-xs text-gray-500 flex flex-wrap items-center justify-between gap-2">
      <span>Landscape Guessr &middot; <%= Date.current.year %></span>
      <span>
        <%= link_to "GitHub", "https://github.com/NU-CS-Software-Studio-Spring-26/project-landscape_guessr", class: "underline hover:text-blue-600" %>
        &middot;
        Built for CS-397 with Rails 8
      </span>
    </footer>
  </body>
</html>
