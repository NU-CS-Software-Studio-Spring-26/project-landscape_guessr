<% content_for :title, @image_set.name %>

<div class="w-full max-w-3xl mx-auto space-y-6 py-6">

  <div>
    <h1 class="heading-page"><%= @image_set.name %></h1>
    <p class="muted mt-1">
      <%= @total_items %> images &middot;
      <span class="<%= @image_set.visibility == 'public' ? 'text-green-600' : 'text-gray-500' %>"><%= @image_set.visibility %></span>
      <% if @image_set.filtered? %>
        &middot; <span class="inline-flex items-center text-xs text-forest-600 bg-forest-50 rounded-full px-2 py-0.5">Filtered</span>
      <% end %>
    </p>
    <% if @image_set.filtered? %>
      <p class="text-xs text-gray-500 mt-1">
        Based on: <%= link_to @image_set.parent_image_set.name, @image_set.parent_image_set, class: "text-forest-600 hover:underline" %>
      </p>
      <% if @image_set.selected_regions.any? || @image_set.custom_areas.any? %>
        <%# max-height + scroll keeps a 50-region filter from pushing the action
            buttons off-screen on mobile. %>
        <div class="flex flex-wrap gap-1 mt-2 max-h-24 overflow-y-auto">
          <% @image_set.selected_regions.each do |region| %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-forest-50 text-forest-700"><%= region.name %></span>
          <% end %>
          <% @image_set.custom_areas.each do |area| %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-700"><%= area["name"].presence || "Custom area" %></span>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <div class="flex items-center gap-2 flex-wrap mt-4">
      <%# Play / Map / Leaderboard need at least one image. Showing them on an
          empty (or unmatched-filter) set just leads users into broken game-start
          flows or empty leaderboards. %>
      <% if @total_items.positive? %>
        <% if practice_image_set?(@image_set) %>
          <%= link_to "Practice", practice_path(practice_set_id: @image_set.id), class: "btn-primary" %>
        <% else %>
          <%= button_to "Play", games_path, method: :post,
                params: { image_set_id: @image_set.id },
                class: "btn-primary" %>
        <% end %>
        <%= link_to "Map", map_image_set_path(@image_set), class: "btn-secondary" %>
        <% unless practice_image_set?(@image_set) %>
          <%= link_to "Leaderboard", leaderboard_games_path(image_set_id: @image_set.id), class: "btn-secondary" %>
        <% end %>
      <% end %>
      <% if @image_set.owned_by?(Current.user) %>
        <% if @image_set.filtered? %>
          <%= link_to "Edit filter", edit_filter_image_set_path(@image_set), class: "btn-secondary" %>
        <% else %>
          <%= link_to "Manage images", locations_image_set_path(@image_set), class: "btn-secondary" %>
          <%= link_to "New filtered set", new_filtered_image_set_path(@image_set), class: "btn-secondary" %>
        <% end %>
        <%= link_to "Settings", edit_image_set_path(@image_set), class: "btn-secondary" %>
      <% end %>
    </div>
  </div>

  <%# AI-import progress banner. Polls /import_status until the job
      hits "completed" or "failed", then reloads. The "X of Y" counter
      hides during phases (fetching / looking_up_images) where we don't
      yet know the total — sitting on "0 / ?" looks stuck even though
      the job is making progress on the Wikidata/Wikipedia side. %>
  <% if @image_set.import_in_progress? %>
    <div class="rounded-xl border border-forest-200 bg-forest-50 px-6 py-5 space-y-3"
         data-controller="ai-import-poll"
         data-ai-import-poll-url-value="<%= import_status_image_set_path(@image_set) %>">
      <p class="text-sm text-forest-800">
        <span data-ai-import-poll-target="status">Starting import…</span>
        <span class="muted hidden" data-counter>
          (<span data-ai-import-poll-target="progress">0</span> /
          <span data-ai-import-poll-target="total">?</span>)
        </span>
      </p>
      <progress data-ai-import-poll-target="bar" value="0" max="100" class="w-full h-2"></progress>
      <p class="muted text-xs">
        This can take a minute or two for big sets. You can leave this page —
        the import keeps running in the background.
      </p>
      <% if @image_set.owned_by?(Current.user) && @image_set.ai_query.present? %>
        <%# Visible escape hatch for stuck imports — a Heroku dyno restart
            or worker crash can leave us in fetching/looking_up_images/inserting
            with nothing actually running. retry_import accepts any non-
            completed state and is safe to spam (unique constraints on
            images.url and image_set_items dedupe). %>
        <%= button_to "Restart import", retry_import_image_set_path(@image_set),
              method: :post, class: "btn-ghost text-xs",
              data: { turbo_confirm: "Restart the import? Use this if it looks stuck." } %>
      <% end %>
    </div>
  <% elsif @image_set.import_state == "failed" %>
    <div class="rounded-xl border border-red-300 bg-red-50 px-6 py-5 space-y-3">
      <p class="text-sm text-red-800 font-medium">Import failed</p>
      <%# import_error contains the raw "#{class}: #{message}" — useful to
          the owner for debugging, but leaks internal class names + paths
          to anyone viewing a public failed set. Owner-only. %>
      <% if @image_set.owned_by?(Current.user) %>
        <p class="text-xs text-red-700"><%= @image_set.import_error.presence || "Unknown error" %></p>
      <% end %>
      <% if @image_set.owned_by?(Current.user) && @image_set.ai_query.present? %>
        <%# Most failures here are transient (Wikidata 5xx, network blip).
            run_query already retries 3× internally; this button covers
            the case where Wikidata was down for >5s. Reuses ai_query
            from the original creation — no re-prompting the AI, no
            extra Gemini cost. %>
        <%= button_to "Retry import", retry_import_image_set_path(@image_set),
              method: :post, class: "btn-secondary text-sm" %>
      <% end %>
    </div>
  <% elsif (failed = @image_set.import_warnings&.dig("failed_types")).present? && @image_set.owned_by?(Current.user) %>
    <%# Partial-success: most categories imported but some failed at
        WDQS (timeout, 5xx past retries). Owner-only — non-owners
        don't need diagnostic noise, the set itself is fine to play. %>
    <div class="rounded-xl border border-amber-300 bg-amber-50 px-6 py-4 space-y-3 text-sm">
      <p class="font-medium text-amber-900">Import notes</p>
      <p class="text-amber-800">
        <strong><%= failed.size %></strong>
        <%= "category".pluralize(failed.size) %> failed at Wikidata (timeout or 5xx):
        <span class="font-mono text-xs"><%= failed.keys.join(", ") %></span>.
        Retries often clear it on the second try.
      </p>
      <%= button_to "Retry import", retry_import_image_set_path(@image_set),
            method: :post, class: "btn-secondary text-xs" %>
    </div>
  <% end %>

  <% if @total_items.zero? %>
    <div class="rounded-xl border border-dashed border-gray-300 bg-gray-50 px-6 py-10 text-center space-y-3">
      <% if @image_set.filtered? %>
        <p class="text-gray-600">No images in the parent set match this filter.</p>
        <% if @image_set.owned_by?(Current.user) %>
          <%= link_to "Edit filter", edit_filter_image_set_path(@image_set), class: "btn-primary inline-block" %>
        <% end %>
      <% elsif @image_set.import_in_progress? %>
        <%# Banner above already explains; no extra empty-state needed. %>
      <% else %>
        <p class="text-gray-600">No images in this set yet.</p>
        <% if @image_set.owned_by?(Current.user) %>
          <%= link_to "Add images", locations_image_set_path(@image_set), class: "btn-primary inline-block" %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/pagination",
              page_url: ->(opts) { image_set_path(@image_set, opts) },
              page: @page, total_pages: @total_pages,
              total_items: @total_items, per_page: @per_page %>

    <%# Each card is a link to the image's detail page, where edit /
        remove-from-set / Open-in-Maps live. Bulk pruning still happens
        on the locations (Manage) page — link at the top of this header. %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% @items.each do |item| %>
        <%= link_to item.image,
              data: { controller: "hide-broken-image" },
              class: "block rounded-md overflow-hidden border border-gray-200 hover:border-blue-300 transition" do %>
          <img src="<%= image_src(item.image, width: 400) %>" alt="<%= item.title.presence || 'Landscape image' %>"
               loading="lazy" decoding="async"
               class="w-full h-32 object-cover">
          <div class="px-2 py-1.5 bg-white">
            <p class="text-xs font-medium text-gray-800 truncate"><%= item.title %></p>
            <p class="text-xs text-gray-500">
              <% if item.latitude && item.longitude %>
                <%= item.latitude.to_f.round(3) %>, <%= item.longitude.to_f.round(3) %>
              <% else %>
                <span class="text-amber-500">No coordinates</span>
              <% end %>
            </p>
          </div>
        <% end %>
      <% end %>
    </div>

    <%= render "shared/pagination",
              page_url: ->(opts) { image_set_path(@image_set, opts) },
              page: @page, total_pages: @total_pages,
              total_items: @total_items, per_page: @per_page %>
  <% end %>

  <%= link_to "Back to sets", image_sets_path, class: "btn-ghost" %>
</div>
