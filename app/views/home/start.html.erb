<% content_for :title, "Start" %>

<div class="w-full max-w-lg mx-auto space-y-8 text-center">
  <div class="space-y-2">
    <h1 class="font-bold text-4xl">Landscape Guessr</h1>
    <p class="text-gray-600">Guess the location of natural landmarks around the world.</p>
  </div>

  <div class="flex flex-col gap-3 items-center">
    <div class="flex flex-col items-center gap-1">
      <%= button_to "Start new game", games_path,
          method: :post,
          data: { turbo: false },
          class: "w-56 rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium text-center cursor-pointer" %>
      <% if @default_set %>
        <p class="text-xs text-gray-500">
          on <%= @default_set.name %> &middot;
          <%= link_to "pick another", image_sets_path, class: "underline hover:text-blue-600" %>
        </p>
      <% end %>
    </div>
    <%= link_to "Previous games", games_path,
        class: "w-56 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium text-center border border-gray-200" %>
    <%= link_to "Practice", practice_path,
        class: "w-56 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium text-center border border-gray-200" %>
    <%= link_to "Image Sets", image_sets_path,
        class: "w-56 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium text-center border border-gray-200" %>
  </div>
</div>
