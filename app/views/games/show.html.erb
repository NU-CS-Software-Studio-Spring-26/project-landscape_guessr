<% content_for :title, "Game ##{@game.id}" %>

<%# "Next round" calls Turbo.visit on the same /games/:id URL, so without
    this Turbo would render the previous round's cached snapshot for an
    instant before the live response arrives — and the player sees the
    old photo flash. no-preview keeps the snapshot cached (back nav stays
    snappy) but skips the stale-preview render. %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview">
<% end %>

<div class="w-full space-y-4">
  <div class="flex justify-between items-center">
    <h1 class="heading-page">
      <% if @image %>
        Round <%= @round %> / <%= @total_rounds %>
      <% else %>
        Game complete
      <% end %>
    </h1>
    <%= link_to "Back to games", games_path, class: "btn-secondary text-sm py-2" %>
  </div>

  <% if @image %>
    <div data-controller="game"
         data-action="guess-map:pinned->game#pinChanged"
         data-game-game-path-value="<%= game_path(@game) %>"
         class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <%# Photo column. Wrap the zoomable container + hint + "view
          original" link in one div so they all share grid column 1;
          the map is column 2. (Earlier the hint <p> sat as a sibling
          and broke the 2-column layout, pushing the map to the next
          row.) %>
      <div data-controller="zoomable"
           data-zoomable-cap-width-value="<%= Image::ZOOM_CAP_WIDTH %>"
           class="space-y-1">
        <%# In-place scroll-zoom: wheel zooms centered on the cursor
            (Google-Maps style), drag pans when zoomed in, double-click
            resets. Source is 3840 px (4K-cached on Wikimedia) so ~8×
            zoom stays crisp; for higher zoom than that, the "View
            original" link below opens the unmodified file (often
            8000+ px) in a new tab.
            object-contain (not -cover): show the entire photo,
            letterboxed if it doesn't match 60vh — cropping the edges
            of a clue photo is confusing in a guesser game. %>
        <div data-zoomable-target="viewport"
             class="h-[60vh] flex items-center justify-center bg-gray-100 rounded-md border border-gray-200 select-none">
          <img src="<%= image_src(@image, width: Image::ZOOM_CAP_WIDTH) %>" alt="Guess this location"
               class="max-w-full max-h-full object-contain">
        </div>
        <div class="flex items-center justify-between gap-2 text-xs text-gray-500">
          <span>scroll to zoom · drag to pan · double-click to reset</span>
          <%# Inline-replace the displayed photo with the unmodified
              original (often 8000+ px). Stays on the page so the player
              doesn't lose context, and the zoom state persists through
              the swap. Hidden by default; the zoomable controller reveals
              it after image load if naturalWidth ≥ the cap (i.e. we got
              a downsized thumbnail and there's a fuller version to load).
              Skipped entirely for Active Storage uploads — those are
              served at native resolution and the helper ignores width. %>
          <% unless @image.photo.attached? %>
            <button type="button"
                    data-zoomable-target="originalButton"
                    data-action="zoomable#loadOriginal"
                    data-zoomable-url-param="<%= image_src(@image) %>"
                    aria-label="Load full quality version of the current image"
                    class="hidden text-gray-500 hover:text-blue-600 underline-offset-2 hover:underline cursor-pointer">
              load full quality
            </button>
          <% end %>
        </div>
      </div>
      <div class="space-y-3">
        <%= render "shared/guess_map", style: @game.image_set&.map_style || "outdoor-v2", bbox: @set_image_bbox %>
        <%= form_with url: guesses_path, local: true, class: "space-y-2" do |f| %>

          <%= hidden_field_tag "guess[game_id]", @game.id %>
          <%= hidden_field_tag "guess[image_id]", @image.id %>
          <%= hidden_field_tag "guess[latitude]", "", data: { game_target: "latitude" } %>
          <%= hidden_field_tag "guess[longitude]", "", data: { game_target: "longitude" } %>
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm text-gray-600">
              Round timer
              <select data-game-target="timerSelect"
                      data-action="change->game#timerChanged"
                      class="ml-2 rounded-md border border-gray-300 px-2 py-1 text-sm">
                <option value="0">Off</option>
                <option value="30">30s</option>
                <option value="60">60s</option>
              </select>
            </label>
            <span data-game-target="timer" class="text-sm text-gray-500">Timer off</span>
          </div>
          <div class="flex items-center gap-2">
            <span data-game-target="readout" class="text-sm text-gray-600">Click the map to drop a pin.</span>
            <p data-game-target="result" class="text-lg font-medium"></p>
            <p data-game-target="otherGuesses" class="hidden text-xs text-gray-500"></p>
            <%= submit_tag "Submit guess", data: { game_target: "submit", action: "game#submitGuess" }, disabled: true,
                class: "btn-primary ml-auto disabled:opacity-40" %>
            <button type="button" data-game-target="next" data-action="game#nextRound"
                    class="btn-primary hidden ml-auto">
              Next round
            </button>
          </div>
        <% end %>
      </div>

      <%# In-site leave confirmation for active games (instead of browser dialogs). %>
      <div data-game-target="leaveModal"
           class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
        <div class="w-full max-w-md rounded-xl border border-gray-200 bg-white p-5 shadow-xl">
          <h2 class="text-lg font-semibold text-gray-900">Leave this game?</h2>
          <p class="mt-2 text-sm text-gray-600">
            You are in the middle of a game. If you leave now, your current progress is lost.
          </p>
          <div class="mt-5 flex justify-end gap-2">
            <button type="button"
                    data-action="game#cancelLeave"
                    class="btn-secondary px-4 py-2 text-sm">
              Stay
            </button>
            <button type="button"
                    data-action="game#confirmLeave"
                    class="btn-primary px-4 py-2 text-sm">
              Leave game
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
