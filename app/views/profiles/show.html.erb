<% content_for :title, "Profile" %>

<div class="w-full max-w-xl mx-auto space-y-6 py-6">
  <div>
    <h1 class="heading-page"><%= @user.username %></h1>
    <p class="muted mt-1"><%= @user.email_address %></p>
  </div>

  <section class="space-y-3">
    <h2 class="heading-section">Stats</h2>
    <div class="grid grid-cols-3 gap-2 sm:gap-3">
      <%= render "shared/stat_card", label: "Games played", value: @games_played %>
      <%= render "shared/stat_card", label: "Best score",
            value: (@best_score ? number_with_delimiter(@best_score.to_i) : "—"), accent: :blue %>
      <%= render "shared/stat_card", label: "Avg score",
            value: (@avg_score ? number_with_delimiter(@avg_score) : "—") %>
    </div>
  </section>

  <section class="space-y-3 pt-4 border-t border-forest-100">
    <h2 class="heading-section">Account</h2>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Reset password", new_password_path, class: "btn-secondary text-sm py-2" %>
      <%= button_to "Sign out", session_path, method: :delete, class: "btn-secondary text-sm py-2" %>
    </div>
  </section>
</div>
