<div class="mx-auto md:w-2/3 w-full">
  <h1 class="heading-page">Sign in</h1>

  <%= form_with url: session_url, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :login, "Email or username", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :login, required: true, autofocus: true, autocomplete: "username", placeholder: "Email or username", value: params[:login], class: "form-input" %>
    </div>

    <div class="my-5">
      <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "form-input" %>
    </div>

    <div class="col-span-6 sm:flex sm:items-center sm:gap-4">
      <div class="inline">
        <%= form.submit "Sign in", class: "btn-primary w-full sm:w-auto" %>
      </div>

      <div class="mt-4 text-sm text-gray-500 sm:mt-0">
        <%= link_to "Forgot password?", new_password_path, class: "text-gray-700 underline hover:no-underline" %>
      </div>
    </div>
  <% end %>

  <p class="mt-6 text-sm text-gray-600">
    Don't have an account?
    <%= link_to "Sign up", new_registration_path, class: "text-blue-600 underline hover:no-underline" %>
  </p>
</div>
