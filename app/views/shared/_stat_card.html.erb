<%# Stat tile: eyebrow label above a big value. %>
<%# Locals: label (string), value (string|number), accent (:gray default | :blue) %>
<% accent_class = (local_assigns[:accent] == :blue) ? "text-amber-500" : "text-forest-900" %>
<div class="bg-forest-50 rounded-xl border border-forest-100 px-4 py-4 text-center">
  <p class="eyebrow"><%= label %></p>
  <p class="text-2xl font-bold font-display <%= accent_class %> mt-1"><%= value %></p>
</div>
