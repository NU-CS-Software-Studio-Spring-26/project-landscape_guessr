<% content_for :title, @image_set.name %>

<div class="w-full max-w-3xl mx-auto space-y-6 py-6">

  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold"><%= @image_set.name %></h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= @items.size %> images &middot;
        <span class="<%= @image_set.visibility == 'public' ? 'text-green-600' : 'text-gray-400' %>"><%= @image_set.visibility %></span>
      </p>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= button_to "Play this set", games_path, method: :post,
            params: { image_set_id: @image_set.id },
            data: { turbo: false },
            class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium cursor-pointer" %>
      <% if @image_set.owned_by?(Current.user) %>
        <%= link_to "Edit locations", locations_image_set_path(@image_set),
              class: "rounded-md px-4 py-2 bg-gray-100 hover:bg-gray-50 font-medium border border-gray-200" %>
        <%= link_to "Settings", edit_image_set_path(@image_set),
              class: "rounded-md px-4 py-2 bg-gray-100 hover:bg-gray-50 font-medium border border-gray-200" %>
      <% end %>
    </div>
  </div>

  <% if @items.empty? %>
    <p class="text-gray-500">No images in this set yet.</p>
  <% else %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% @items.each do |item| %>
        <div class="rounded-md overflow-hidden border border-gray-200 relative group">
          <img src="<%= image_src(item.image, width: 400) %>" alt="<%= item.title %>"
               class="w-full h-32 object-cover">
          <div class="px-2 py-1.5 bg-white">
            <p class="text-xs font-medium text-gray-800 truncate"><%= item.title %></p>
            <p class="text-xs text-gray-400">
              <% if item.latitude && item.longitude %>
                <%= item.latitude.to_f.round(3) %>, <%= item.longitude.to_f.round(3) %>
              <% else %>
                <span class="text-amber-500">No coordinates</span>
              <% end %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= link_to "Back to sets", image_sets_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>
