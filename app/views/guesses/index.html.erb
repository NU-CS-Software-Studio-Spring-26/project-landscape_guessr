<% content_for :title, "Guesses" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="heading-page">Guesses</h1>
    <% if admin? %>
      <%= link_to "New guess", new_guess_path, class: "btn-primary" %>
    <% end %>
  </div>

  <div id="guesses" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @guesses.any? %>
      <% @guesses.each do |guess| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render guess %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", guess, class: "btn-secondary w-full sm:w-auto" %>
            <% if admin? %>
              <%= link_to "Edit", edit_guess_path(guess), class: "btn-secondary w-full sm:w-auto" %>
              <%= button_to "Destroy", guess, method: :delete, class: "btn-danger w-full sm:w-auto", data: { turbo_confirm: "Are you sure?" } %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No guesses found.</p>
    <% end %>
  </div>
</div>
