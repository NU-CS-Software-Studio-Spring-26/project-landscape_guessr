<% content_for :title, "Images" %>

<div class="w-full max-w-5xl mx-auto space-y-6 py-6">
  <div class="flex justify-between items-center gap-3">
    <h1 class="heading-page">
      Images <span class="muted text-base font-normal">(<%= @total_items %>)</span>
    </h1>
    <div class="flex gap-2 shrink-0">
      <%= link_to "Map view", map_images_path, class: "btn-secondary" %>
      <% if admin? %>
        <%= link_to "New image", new_image_path, class: "btn-primary" %>
      <% end %>
    </div>
  </div>

  <%= render "image_sets/pagination",
            page_url: ->(n) { images_path(page: n) },
            page: @page, total_pages: @total_pages,
            total_items: @total_items, per_page: @per_page %>

  <% if @images.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% @images.each do |image| %>
        <%= render image %>
      <% end %>
    </div>
  <% else %>
    <p class="text-center my-10 text-gray-500">No images found.</p>
  <% end %>

  <%= render "image_sets/pagination",
            page_url: ->(n) { images_path(page: n) },
            page: @page, total_pages: @total_pages,
            total_items: @total_items, per_page: @per_page %>
</div>
