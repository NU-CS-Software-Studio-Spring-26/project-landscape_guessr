<% content_for :title, "Saved Practice" %>

<div class="w-full max-w-5xl mx-auto space-y-6 py-4">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="heading-page">Saved for practice</h1>
    <div class="flex flex-wrap items-center gap-2">
      <% if @saved_practice_set && @saved_images.any? %>
        <%= link_to "Practice saved set",
              practice_path(practice_set_id: @saved_practice_set.id),
              class: "btn-primary" %>
      <% end %>
      <%= link_to "Free practice", practice_path, class: "btn-secondary" %>
    </div>
  </div>

  <% if @saved_images.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @saved_images.each do |image| %>
        <div class="rounded-md border border-gray-200 overflow-hidden bg-white">
          <img src="<%= image_src(image, width: 900) %>"
               alt="<%= image.title.presence || "Saved practice image" %>"
               loading="lazy"
               decoding="async"
               class="w-full h-44 object-cover">
          <div class="p-3 space-y-3">
            <div>
              <p class="text-sm font-semibold text-gray-900 truncate"><%= image.title.presence || "Untitled image" %></p>
              <p class="text-xs text-gray-500">
                <%= image.latitude.to_f.round(3) %>, <%= image.longitude.to_f.round(3) %>
              </p>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to "Practice this image",
                    practice_path(
                      image_id: image.id,
                      practice_set_id: @saved_practice_set&.id
                    ),
                    class: "btn-primary text-sm" %>
              <%= button_to "Remove", practice_unsave_path(image.id),
                    method: :delete,
                    params: { from_saved: 1 },
                    class: "btn-secondary text-sm py-2" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-gray-200 bg-gray-50 px-5 py-6 space-y-3">
      <p class="text-gray-700 font-medium">You do not have saved practice images yet.</p>
      <p class="text-sm text-gray-500">Play a practice round, then use "Save for practice" after you reveal the answer.</p>
      <%= link_to "Start practicing", practice_path, class: "btn-primary inline-flex" %>
    </div>
  <% end %>
</div>
