<% content_for :title, "Challenges" %>

<div class="page-container">
  <div class="flex items-center justify-between">
    <h1 class="heading-page">Challenges</h1>
    <%= link_to "New challenge", new_challenge_path, class: "btn-primary text-sm" %>
  </div>

  <%# Join a friend's challenge %>
  <div class="rounded-xl border border-gray-200 px-5 py-4 space-y-2">
    <p class="text-sm font-medium text-gray-700">Have a friend's link?</p>
    <form onsubmit="event.preventDefault(); var raw = this.querySelector('input').value.trim(); var token = raw.split('/').pop(); if (token) window.location = '/challenges/' + token;"
          class="flex gap-2">
      <input type="text" placeholder="Paste link or code (e.g. abc12345)"
             class="form-input flex-1 mt-0" autocomplete="off">
      <button type="submit" class="btn-secondary shrink-0">Go</button>
    </form>
  </div>

  <% if @challenges.any? %>
    <div class="divide-y divide-gray-100 border border-gray-200 rounded-lg overflow-hidden">
      <% @challenges.each do |c| %>
        <%= link_to challenge_path(c), class: "flex items-center gap-4 px-4 py-3 bg-white hover:bg-gray-50 transition" do %>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-gray-800 truncate">
              <%= c.image_set&.name || "Default set" %>
            </p>
            <p class="muted text-xs">
              by <%= c.challenger.username %> &middot; <%= time_ago_in_words(c.created_at) %> ago
            </p>
          </div>
          <% my_game = c.game_for(Current.user) %>
          <% completed_count = c.completed_games.size %>
          <div class="text-right shrink-0">
            <% if my_game&.completed_at %>
              <p class="text-sm font-semibold text-blue-600"><%= number_with_delimiter(my_game.score.to_i) %></p>
              <p class="text-xs text-gray-400"><%= completed_count %> finished</p>
            <% elsif my_game %>
              <span class="text-xs font-medium bg-blue-100 text-blue-700 rounded-full px-2.5 py-0.5">In game</span>
            <% else %>
              <span class="text-xs font-medium bg-green-100 text-green-700 rounded-full px-2.5 py-0.5">Play now</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 space-y-3">
      <p class="text-gray-500">No challenges yet.</p>
      <%= link_to "Create one", new_challenge_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
