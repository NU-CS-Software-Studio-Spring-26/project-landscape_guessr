<% content_for :title, "Games" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="heading-page">Games</h1>
    <div class="flex space-x-2">
      <%= link_to "Leaderboard", leaderboard_games_path, class: "btn-secondary" %>
      <%# Land on /image_sets so the user picks which set to play. The home
          page's "Start new game" still kicks straight to the system default. %>
      <%= link_to "New game", image_sets_path, class: "btn-primary" %>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-2 mt-6 mb-4 text-sm">
    <% [["All", "all"], ["In progress", "in_progress"], ["Completed", "completed"]].each do |label, value| %>
      <%= link_to label, games_path(status: value, sort: @sort, direction: @direction, per_page: @per_page),
            class: "rounded-full px-3 py-1 text-xs font-medium #{@status == value ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200"}" %>
    <% end %>

    <div class="ml-auto flex items-center gap-2">
      <label for="sort_dir" class="muted">Sort by</label>
      <%= select_tag :sort_dir,
            options_for_select(
              [
                ["Newest first",  games_path(status: @status, sort: "created_at", direction: "desc", per_page: @per_page)],
                ["Oldest first",  games_path(status: @status, sort: "created_at", direction: "asc",  per_page: @per_page)],
                ["Highest score", games_path(status: @status, sort: "score",      direction: "desc", per_page: @per_page)],
                ["Lowest score",  games_path(status: @status, sort: "score",      direction: "asc",  per_page: @per_page)]
              ],
              games_path(status: @status, sort: @sort, direction: @direction, per_page: @per_page)
            ),
            onchange: "Turbo.visit(this.value)",
            class: "select-with-arrow rounded-md border border-gray-300 pl-3 pr-8 py-1.5 text-sm cursor-pointer bg-white" %>
    </div>
  </div>

  <%= render "shared/pagination",
            page_url: ->(opts) { games_path({ status: @status, sort: @sort, direction: @direction }.merge(opts)) },
            page: @page, total_pages: @total_pages,
            total_items: @total_items, per_page: @per_page %>

  <div id="games" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @games.any? %>
      <% @games.each do |game| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render game %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <% if game.status == "completed" %>
              <%= link_to "View results", results_game_path(game), class: "btn-secondary w-full sm:w-auto" %>
            <% else %>
              <%= link_to "Continue", game, class: "btn-secondary w-full sm:w-auto" %>
            <% end %>
            <% if admin? %>
              <%= link_to "Edit", edit_game_path(game), class: "btn-secondary w-full sm:w-auto" %>
            <% end %>
            <%= button_to "Delete", game, method: :delete,
                  data: { turbo_confirm: "Delete this game? This cannot be undone." },
                  class: "btn-danger w-full sm:w-auto" %>
          </div>
        </div>
      <% end %>

      <%= render "shared/pagination",
                page_url: ->(opts) { games_path({ status: @status, sort: @sort, direction: @direction }.merge(opts)) },
                page: @page, total_pages: @total_pages,
                total_items: @total_items, per_page: @per_page %>
    <% else %>
      <p class="text-center my-10 text-gray-500">
        <% case @status %>
        <% when "completed" %>
          No completed games yet — click "New game" to play your first.
        <% when "in_progress" %>
          No games in progress.
        <% else %>
          You haven't started any games yet — click "New game" to play your first.
        <% end %>
      </p>
    <% end %>
  </div>
</div>
