<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) ? "#{content_for(:title)} — Landscape Guessr" : "Landscape Guessr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Landscape Guessr">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans antialiased bg-white text-forest-900 min-h-screen flex flex-col">

    <header class="sticky top-0 z-20 bg-white/95 backdrop-blur-sm border-b border-forest-100">
      <nav aria-label="Primary" class="container mx-auto px-5 h-14 flex justify-between items-center">
        <div class="flex items-center gap-6">
          <%= link_to "Landscape Guessr", root_path,
                class: "font-display font-semibold text-forest-800 text-lg tracking-tight hover:text-forest-600 transition-colors" %>
          <% if authenticated? %>
            <%= link_to "Games", games_path,
                  class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors" %>
            <%= link_to "Image Sets", image_sets_path,
                  class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors hidden sm:inline" %>
            <%= link_to "Challenges", challenges_path,
                  class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors" %>
          <% end %>
        </div>
        <div class="flex items-center gap-3">
          <% if authenticated? %>
            <%= link_to Current.user.username, profile_path,
                  class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors hidden sm:inline" %>
            <%= button_to "Sign out", session_path, method: :delete,
                  class: "btn-secondary text-sm py-1.5 px-3" %>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "btn-secondary text-sm py-1.5 px-3" %>
            <%= link_to "Sign up", new_registration_path, class: "btn-primary text-sm py-1.5 px-3" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main aria-label="Main content" class="container mx-auto px-5 py-8 flex-1">
      <% if notice = flash[:notice] %>
        <div class="mb-6 py-3 px-4 bg-forest-50 text-forest-700 font-medium rounded-xl border border-forest-200 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-forest-500 shrink-0"></span>
          <%= notice %>
        </div>
      <% end %>
      <% if alert = flash[:alert] %>
        <div class="mb-6 py-3 px-4 bg-red-50 text-red-700 font-medium rounded-xl border border-red-200 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500 shrink-0"></span>
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="bg-forest-50 border-t border-forest-100 mt-auto">
      <div class="container mx-auto px-5 py-6 text-xs text-forest-700 flex flex-wrap items-center justify-between gap-2">
        <span class="font-medium">Landscape Guessr &middot; <%= Date.current.year %></span>
        <span class="flex items-center gap-3">
          <%= link_to "About", about_path, class: "hover:text-forest-900 transition-colors" %>
          <%= link_to "Legal", legal_path, class: "hover:text-forest-900 transition-colors" %>
          <%= link_to "GitHub", "https://github.com/NU-CS-Software-Studio-Spring-26/project-landscape_guessr",
                class: "hover:text-forest-900 transition-colors" %>
          <span class="text-forest-400">Built for CS-397 with Rails 8</span>
        </span>
      </div>
    </footer>

  </body>
</html>
