<% content_for :title, @image_set.name %>

<div class="w-full max-w-3xl mx-auto space-y-6 py-6">

  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="heading-page"><%= @image_set.name %></h1>
      <p class="muted mt-1">
        <%= @total_items %> images &middot;
        <span class="<%= @image_set.visibility == 'public' ? 'text-green-600' : 'text-gray-500' %>"><%= @image_set.visibility %></span>
      </p>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= button_to "Play this set", games_path, method: :post,
            params: { image_set_id: @image_set.id },
            class: "btn-primary" %>
      <%= link_to "Leaderboard", leaderboard_games_path(image_set_id: @image_set.id),
            class: "btn-secondary" %>
      <%= link_to "Map", map_image_set_path(@image_set),
            class: "btn-secondary" %>
      <% if @image_set.owned_by?(Current.user) %>
        <%= link_to "Manage images", locations_image_set_path(@image_set), class: "btn-secondary" %>
        <%= link_to "Settings",       edit_image_set_path(@image_set),      class: "btn-secondary" %>
      <% end %>
    </div>
  </div>

  <% if @total_items.zero? %>
    <div class="rounded-xl border border-dashed border-gray-300 bg-gray-50 px-6 py-10 text-center space-y-3">
      <p class="text-gray-600">No images in this set yet.</p>
      <% if @image_set.owned_by?(Current.user) %>
        <%= link_to "Add images", locations_image_set_path(@image_set), class: "btn-primary inline-block" %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/pagination",
              page_url: ->(opts) { image_set_path(@image_set, opts) },
              page: @page, total_pages: @total_pages,
              total_items: @total_items, per_page: @per_page %>

    <%# Each card is a link to the image's detail page, where edit /
        remove-from-set / Open-in-Maps live. Bulk pruning still happens
        on the locations (Manage) page — link at the top of this header. %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% @items.each do |item| %>
        <%= link_to item.image,
              class: "block rounded-md overflow-hidden border border-gray-200 hover:border-blue-300 transition" do %>
          <img src="<%= image_src(item.image, width: 400) %>" alt="<%= item.title %>"
               loading="lazy" decoding="async"
               class="w-full h-32 object-cover">
          <div class="px-2 py-1.5 bg-white">
            <p class="text-xs font-medium text-gray-800 truncate"><%= item.title %></p>
            <p class="text-xs text-gray-500">
              <% if item.latitude && item.longitude %>
                <%= item.latitude.to_f.round(3) %>, <%= item.longitude.to_f.round(3) %>
              <% else %>
                <span class="text-amber-500">No coordinates</span>
              <% end %>
            </p>
          </div>
        <% end %>
      <% end %>
    </div>

    <%= render "shared/pagination",
              page_url: ->(opts) { image_set_path(@image_set, opts) },
              page: @page, total_pages: @total_pages,
              total_items: @total_items, per_page: @per_page %>
  <% end %>

  <%= link_to "Back to sets", image_sets_path, class: "btn-ghost" %>
</div>
