<% content_for :title, "Challenges" %>

<div class="page-container">
  <div class="flex items-center justify-between">
    <h1 class="heading-page">Challenges</h1>
    <%= link_to "New challenge", new_challenge_path, class: "btn-primary text-sm" %>
  </div>

  <%# Join a friend's challenge %>
  <div class="card px-5 py-4 space-y-2">
    <p class="text-sm font-semibold text-forest-800">Have a friend's link?</p>
    <p class="muted text-xs">Paste their challenge link or 8-character code below.</p>
    <form onsubmit="event.preventDefault(); var raw = this.querySelector('input').value.trim(); var token = raw.split('/').pop(); if (token) window.location = '/challenges/' + token;"
          class="flex gap-2">
      <input type="text" placeholder="Paste link or code (e.g. abc12345)"
             class="form-input flex-1 mt-0" autocomplete="off">
      <button type="submit" class="btn-secondary shrink-0">Go</button>
    </form>
  </div>

  <% if @challenges.any? %>
    <div class="card overflow-hidden divide-y divide-forest-50">
      <% @challenges.each do |c| %>
        <%= link_to challenge_path(c), class: "flex items-center gap-4 px-5 py-4 bg-white hover:bg-forest-50 transition-colors" do %>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-forest-900 truncate">
              <%= c.image_set&.name || "Default set" %>
            </p>
            <p class="muted text-xs">
              by <%= c.challenger.username %> &middot; <%= time_ago_in_words(c.created_at) %> ago
            </p>
          </div>
          <% my_game = c.game_for(Current.user) %>
          <% completed_count = c.completed_games.size %>
          <div class="text-right shrink-0">
            <% if my_game&.completed_at %>
              <p class="font-bold text-amber-500 font-display"><%= number_with_delimiter(my_game.score.to_i) %></p>
              <p class="text-xs text-gray-400"><%= completed_count %> finished</p>
            <% elsif my_game %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">In game</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-forest-100 text-forest-700">Play now</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card px-6 py-16 text-center space-y-3">
      <p class="text-gray-400 text-sm">No challenges yet.</p>
      <%= link_to "Create your first challenge", new_challenge_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
