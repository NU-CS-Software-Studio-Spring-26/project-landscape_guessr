<%# Bordered stat tile: small uppercase label above a big number.
    Usage: <%%= render "shared/stat_card", label: "Best score", value: 12345, accent: :blue %>
    Locals: label (string), value (string|number), accent (:gray default | :blue) %>
<% accent_color = (local_assigns[:accent] == :blue) ? "text-blue-600" : "text-gray-800" %>
<div class="rounded-lg border border-gray-200 px-4 py-3 text-center">
  <p class="eyebrow"><%= label %></p>
  <p class="text-2xl font-bold <%= accent_color %> mt-1"><%= value %></p>
</div>
