<%# Completed generation: preview card, image-source toggle, and the
    "Import images" form. The hidden fields posted to ai_create carry
    the AI's SPARQL pattern + chosen image source — those values are
    server-controlled (they came from the AiGeneration record), so
    importing reuses the exact query the user just previewed. %>
<% result = generation.result || {} %>
<% preview = generation.preview %>
<% count   = generation.result_count %>

<section class="card p-4 space-y-4">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="eyebrow">Proposed set</p>
      <h2 class="text-xl font-semibold text-forest-900 mt-1"><%= result[:set_name] %></h2>
      <% if result[:fetch_strategy] == "random_sample" %>
        <p class="text-xs text-forest-700 mt-1">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-amber-50 text-amber-800 font-medium">Random sample</span>
          up to 10,000 per category
        </p>
      <% end %>
    </div>
    <div class="text-right text-sm">
      <% if count.nil? %>
        <p class="text-amber-700">Couldn't count yet</p>
      <% elsif result[:fetch_strategy] == "random_sample" %>
        <%# bd:sample returns exactly the cap when count >= cap. Show
            "10,000+" instead of "10,000" so the user knows they're
            seeing a sampled lower bound, not a true total. %>
        <% if count >= 10_000 %>
          <p><strong class="text-forest-900">10,000+</strong> matching items</p>
          <p class="muted">Sampling 10,000 random items per category</p>
        <% else %>
          <p><strong class="text-forest-900"><%= number_with_delimiter(count) %></strong> matching items</p>
          <p class="muted">All <%= number_with_delimiter(count) %> will be imported</p>
        <% end %>
      <% else %>
        <p><strong class="text-forest-900"><%= number_with_delimiter(count) %></strong> matching images</p>
        <% if count > 10_000 %>
          <p class="muted">First 10,000 will be imported</p>
        <% end %>
      <% end %>
    </div>
  </div>

  <p class="text-sm text-forest-900">
    <span class="eyebrow mr-1">AI</span>
    <%= result[:explanation] %>
  </p>

  <%# Sample thumbnails. ?width=400 matches show-page's image_src
      width so the browser cache can reuse them. %>
  <% if preview.any? %>
    <div>
      <p class="eyebrow mb-2">Sample (<%= preview.size %> of <%= count || "?" %>)</p>
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
        <% preview.each do |row| %>
          <a href="<%= row[:url] %>" target="_blank" rel="noopener"
             title="<%= row[:title] %>"
             data-controller="hide-broken-image"
             class="group relative block aspect-square overflow-hidden rounded-md bg-forest-50 border border-forest-100">
            <img src="<%= row[:url] %>?width=400"
                 alt="<%= row[:title] %>"
                 loading="lazy"
                 class="w-full h-full object-cover transition group-hover:opacity-90" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent text-white text-[11px] leading-tight font-medium px-2 py-2 opacity-0 group-hover:opacity-100 transition-opacity line-clamp-2">
              <%= row[:title] %>
            </div>
          </a>
        <% end %>
      </div>
    </div>
  <% elsif count == 0 %>
    <p class="text-sm text-amber-700">
      The AI's query matched 0 images. Try refining your prompt — be more specific
      (e.g. add a country) or use a more common category.
    </p>
  <% end %>

  <%# Import form. Only USER-controllable inputs (name, visibility,
      image-source toggle) live here; the AI's SPARQL pattern,
      explanation, model, and prompt all come from the AiGeneration
      record server-side — see ai_create. This means a tampered hidden
      field can't smuggle malicious SPARQL past parse_submit's
      validation. %>
  <%= form_with url: ai_create_image_sets_path, local: true, class: "space-y-3 pt-2 border-t border-forest-100" do |f| %>
    <%= hidden_field_tag :generation_id, generation.id %>

    <div>
      <label class="text-sm font-medium text-forest-900">Set name</label>
      <%= text_field_tag :name, result[:set_name], class: "form-input" %>
    </div>
    <div>
      <label class="text-sm font-medium text-forest-900">Visibility</label>
      <%= select_tag :visibility, options_for_select([ [ "Private", "private" ], [ "Public", "public" ] ], "private"), class: "form-input select-with-arrow" %>
    </div>

    <details class="text-sm">
      <summary class="cursor-pointer text-forest-700 hover:text-forest-900">Image options</summary>
      <div class="mt-3 pl-2 space-y-2">
        <p class="muted">Where should the photos come from?</p>
        <label class="block">
          <input type="radio" name="ai_image_source" value="wikidata_p18" <%= "checked" if result[:image_source] == "wikidata_p18" %>>
          Wikidata photos (faster, but sometimes older)
        </label>
        <label class="block">
          <input type="radio" name="ai_image_source" value="wikipedia_pageimages" <%= "checked" if result[:image_source] == "wikipedia_pageimages" %>>
          Wikipedia article photos (fresher; slower import)
        </label>
      </div>
    </details>

    <details class="text-sm">
      <summary class="cursor-pointer text-forest-700 hover:text-forest-900">Show query (advanced)</summary>
      <pre class="mt-3 p-3 bg-forest-50 border border-forest-100 rounded-md overflow-x-auto text-xs text-forest-900"><%= result[:sparql_pattern] %></pre>
    </details>

    <div class="flex justify-end">
      <%= submit_tag "Import images", class: "btn-primary cursor-pointer" %>
    </div>
  <% end %>
</section>
