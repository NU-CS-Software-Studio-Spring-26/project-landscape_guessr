<%= form_with model: image_set, class: "space-y-4" do |f| %>
  <%= render "shared/form_errors", record: image_set %>

  <div class="space-y-1">
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <div class="relative" data-controller="name-constraints">
      <%= f.text_field :name,
            class: field_class(image_set, :name),
            placeholder: "My Landscape Set",
            required: true,
            minlength: ImageSet::NAME_MIN_LENGTH,
            maxlength: ImageSet::NAME_MAX_LENGTH,
            pattern: ImageSet::NAME_HTML_PATTERN,
            title: "#{ImageSet::NAME_MIN_LENGTH}–#{ImageSet::NAME_MAX_LENGTH} characters. #{ImageSet::NAME_FORMAT_MESSAGE.capitalize}.",
            data: { action: "mouseenter->name-constraints#show mouseleave->name-constraints#hide focus->name-constraints#show blur->name-constraints#hide" } %>
      <%= render "image_sets/name_constraints_tooltip" %>
    </div>
  </div>

  <div class="space-y-1">
    <%= f.label :visibility, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :visibility, [["Private (only you)", "private"], ["Public (anyone can play)", "public"]],
          {}, class: field_class(image_set, :visibility) %>
  </div>

  <div class="space-y-1">
    <%= f.label :map_style, "Map style", class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :map_style, [
          ["Outdoor (terrain, peaks, POIs)",     "outdoor-v2"],
          ["Streets (urban detail)",             "streets-v2"],
          ["Bright (light, label-heavy)",        "bright-v2"],
          ["Topographic (contour-emphasis)",     "topo-v2"],
          ["Satellite (aerial imagery)",         "satellite"],
          ["Hybrid (satellite + labels)",        "hybrid"]
        ], {}, class: field_class(image_set, :map_style) %>
    <p class="text-xs text-gray-500">Used by the guess map while playing this set and the set's map view.</p>
  </div>

  <%= f.submit image_set.persisted? ? "Save changes" : "Create set", class: "btn-primary" %>
<% end %>
