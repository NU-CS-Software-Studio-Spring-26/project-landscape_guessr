<% content_for :title, "Landscape Guessr" %>

<% if authenticated? %>
  <div class="w-full max-w-lg mx-auto space-y-8 text-center">
    <div class="space-y-2">
      <h1 class="heading-hero">Landscape Guessr</h1>
      <p class="text-gray-600">Guess the location of natural landmarks around the world.</p>
    </div>

    <div class="flex flex-col gap-3 items-center">
      <div class="flex flex-col items-center gap-1">
        <%= button_to "Start new game", games_path, method: :post,
              class: "btn-primary w-56" %>
        <% if @default_set %>
          <p class="text-xs text-gray-500">
            on <%= @default_set.name %> &middot;
            <%= link_to "pick another", image_sets_path, class: "underline hover:text-blue-600" %>
          </p>
        <% end %>
      </div>
      <%= link_to "Previous games", games_path, class: "btn-secondary w-56" %>
      <%= link_to "Practice",       practice_path,  class: "btn-secondary w-56" %>
      <%= link_to "Image Sets",     image_sets_path, class: "btn-secondary w-56" %>
    </div>
  </div>

<% else %>

  <%# Hero %>
  <div class="text-center space-y-6 py-8">
    <div class="space-y-4">
      <h1 class="text-5xl font-bold tracking-tight">Landscape Guessr</h1>
      <p class="text-xl text-gray-600 max-w-xl mx-auto">
        You're shown a photo of a natural landmark. Drop a pin on the world map and see how close you can get.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center pt-2">
      <%= link_to "Sign up free", new_registration_path, class: "btn-primary text-base px-6 py-3" %>
      <%= link_to "Sign in", new_session_path, class: "btn-secondary text-base px-6 py-3" %>
    </div>
    <p class="text-sm text-gray-500">
      No account? <%= link_to "Try practice mode", practice_path, class: "underline hover:text-blue-600" %>
    </p>
  </div>

  <%# How it works %>
  <div class="mt-10 py-10 border-t border-gray-100">
    <h2 class="heading-section text-center mb-10">How it works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 max-w-2xl mx-auto text-center">
      <div class="space-y-3">
        <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-700 font-bold text-lg flex items-center justify-center mx-auto">1</div>
        <h3 class="font-semibold">See a photo</h3>
        <p class="muted">You're shown a photograph of a natural landscape &mdash; a mountain, lake, canyon, or coastline.</p>
      </div>
      <div class="space-y-3">
        <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-700 font-bold text-lg flex items-center justify-center mx-auto">2</div>
        <h3 class="font-semibold">Drop your pin</h3>
        <p class="muted">Click anywhere on a world map to place your best guess for where the photo was taken.</p>
      </div>
      <div class="space-y-3">
        <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-700 font-bold text-lg flex items-center justify-center mx-auto">3</div>
        <h3 class="font-semibold">See your score</h3>
        <p class="muted">The closer your guess, the higher you score. Up to 5,000 points per round across 5 rounds.</p>
      </div>
    </div>
  </div>

  <%# Stats strip %>
  <% if @game_count > 0 || @image_count > 0 %>
    <div class="py-10 border-t border-gray-100">
      <div class="flex flex-wrap justify-center gap-16 text-center">
        <% if @game_count > 0 %>
          <div>
            <div class="text-3xl font-bold text-blue-600"><%= number_with_delimiter(@game_count) %></div>
            <div class="eyebrow mt-1">Games played</div>
          </div>
        <% end %>
        <% if @image_count > 0 %>
          <div>
            <div class="text-3xl font-bold text-blue-600"><%= number_with_delimiter(@image_count) %></div>
            <div class="eyebrow mt-1">Landscapes</div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

<% end %>
