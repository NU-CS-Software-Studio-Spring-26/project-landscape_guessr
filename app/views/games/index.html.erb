<% content_for :title, "Games" %>

<div class="w-full space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="heading-page">My Games</h1>
    <div class="flex gap-2">
      <%= link_to "Leaderboard", leaderboard_games_path, class: "btn-secondary text-sm" %>
      <%= link_to "New game", image_sets_path, class: "btn-primary text-sm" %>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-2">
    <% [ [ "All", "all" ], [ "In progress", "in_progress" ], [ "Completed", "completed" ] ].each do |label, value| %>
      <%= link_to label, games_path(status: value, sort: @sort, direction: @direction, per_page: @per_page),
            class: "rounded-full px-3.5 py-1.5 text-xs font-semibold transition-colors #{@status == value ? "bg-forest-600 text-white shadow-sm" : "bg-forest-50 text-forest-700 hover:bg-forest-100 border border-forest-200"}" %>
    <% end %>

    <div class="ml-auto flex items-center gap-2">
      <label for="sort_dir" class="muted text-xs">Sort</label>
      <%= select_tag :sort_dir,
            options_for_select(
              [
                [ "Newest first",  games_path(status: @status, sort: "created_at", direction: "desc", per_page: @per_page) ],
                [ "Oldest first",  games_path(status: @status, sort: "created_at", direction: "asc",  per_page: @per_page) ],
                [ "Highest score", games_path(status: @status, sort: "score",      direction: "desc", per_page: @per_page) ],
                [ "Lowest score",  games_path(status: @status, sort: "score",      direction: "asc",  per_page: @per_page) ]
              ],
              games_path(status: @status, sort: @sort, direction: @direction, per_page: @per_page)
            ),
            onchange: "Turbo.visit(this.value)",
            class: "select-with-arrow rounded-lg border border-forest-200 pl-3 pr-8 py-1.5 text-sm cursor-pointer bg-white text-forest-800 focus:outline-none focus:ring-2 focus:ring-forest-200 focus:border-forest-600" %>
    </div>
  </div>

  <%= render "shared/pagination",
            page_url: ->(opts) { games_path({ status: @status, sort: @sort, direction: @direction }.merge(opts)) },
            page: @page, total_pages: @total_pages,
            total_items: @total_items, per_page: @per_page %>

  <div class="space-y-3">
    <% if @games.any? %>
      <% @games.each do |game| %>
        <div class="card px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-3 hover:border-forest-200 transition-colors">
          <%= render game %>
          <div class="flex flex-wrap gap-2 shrink-0">
            <% if game.status == "completed" %>
              <%= link_to "Results", results_game_path(game), class: "btn-secondary text-sm py-2 px-3" %>
            <% else %>
              <%= link_to "Continue", game, class: "btn-primary text-sm py-2 px-3" %>
            <% end %>
            <% if admin? %>
              <%= link_to "Edit", edit_game_path(game), class: "btn-secondary text-sm py-2 px-3" %>
            <% end %>
            <%= button_to "Delete", game, method: :delete,
                  data: { turbo_confirm: "Delete this game? This cannot be undone." },
                  class: "btn-ghost text-red-500 hover:text-red-700 text-sm py-2 px-3" %>
          </div>
        </div>
      <% end %>

      <%= render "shared/pagination",
                page_url: ->(opts) { games_path({ status: @status, sort: @sort, direction: @direction }.merge(opts)) },
                page: @page, total_pages: @total_pages,
                total_items: @total_items, per_page: @per_page %>
    <% else %>
      <div class="card px-6 py-16 text-center space-y-3">
        <p class="text-gray-400 text-sm">
          <% if @status == "completed" %>No completed games yet.
          <% elsif @status == "in_progress" %>No games in progress.
          <% else %>You haven't started any games yet.
          <% end %>
        </p>
        <%= link_to "Start your first game", image_sets_path, class: "btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
