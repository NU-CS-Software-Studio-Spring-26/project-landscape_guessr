<% content_for :title, "Leaderboard" %>

<div class="w-full max-w-2xl mx-auto space-y-6 py-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold">Leaderboard</h1>
      <p class="text-sm text-gray-500">Top <%= @games.size %> games — highest GeoGuessr-style score over <%= @total_rounds %> rounds wins.</p>
    </div>
    <%= link_to "Back to games", games_path, class: "rounded-md px-3 py-2 bg-gray-100 hover:bg-gray-50 font-medium" %>
  </div>

  <% if @games.any? %>
    <table class="min-w-full text-left">
      <thead class="text-xs font-semibold text-gray-500 uppercase tracking-wide border-b">
        <tr>
          <th class="py-2 pr-4">#</th>
          <th class="py-2 pr-4">Player</th>
          <th class="py-2 pr-4">Score</th>
          <th class="py-2 pr-4">Completed</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @games.each_with_index do |game, i| %>
          <tr>
            <td class="py-2 pr-4 font-semibold text-gray-700"><%= i + 1 %></td>
            <td class="py-2 pr-4"><%= game.user.email_address %></td>
            <td class="py-2 pr-4 font-medium"><%= number_with_delimiter(game.score) %></td>
            <td class="py-2 pr-4 text-gray-500 text-sm"><%= game.completed_at.to_fs(:short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center my-10 text-gray-500">No completed games yet — be the first!</p>
  <% end %>
</div>
