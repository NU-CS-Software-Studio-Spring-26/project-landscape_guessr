<% content_for :title, "Practice" %>

<%# "Next image" reloads the same /practice URL via Turbo.visit, so without
    this Turbo would render the previous round's cached snapshot briefly
    and the player sees the old photo flash. no-preview keeps the snapshot
    cached (back nav stays snappy) but skips the stale-preview render. %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview">
<% end %>

<div data-controller="practice"
     data-action="guess-map:pinned->practice#pinChanged"
     data-practice-image-id-value="<%= @image.id %>"
     data-practice-check-url-value="<%= practice_check_path %>"
     data-practice-time-limit-value="<%= @time_limit_seconds.to_i %>"
     class="w-full space-y-6">

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <h1 class="heading-page">Where is this?</h1>
    <div class="flex flex-wrap items-center gap-2 text-xs text-gray-500">
      <span>Timer:</span>
      <button type="button"
              data-practice-target="timerOption"
              data-action="practice#setTimer"
              data-practice-seconds-param="0"
              aria-pressed="<%= @time_limit_seconds.nil? %>"
              class="rounded-full border px-2.5 py-1 font-medium transition-colors cursor-pointer <%= @time_limit_seconds.nil? ? 'bg-blue-100 text-blue-800 border-blue-300 shadow-sm' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50' %>">
        Off
      </button>
      <% [30, 60, 120].each do |seconds| %>
        <button type="button"
                data-practice-target="timerOption"
                data-action="practice#setTimer"
                data-practice-seconds-param="<%= seconds %>"
                aria-pressed="<%= @time_limit_seconds == seconds %>"
                class="rounded-full border px-2.5 py-1 font-medium transition-colors cursor-pointer <%= @time_limit_seconds == seconds ? 'bg-blue-100 text-blue-800 border-blue-300 shadow-sm' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50' %>">
          <%= seconds %>s
        </button>
      <% end %>
    </div>
  </div>

  <div data-practice-target="timerPanel"
       class="flex flex-wrap items-center justify-between gap-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 <%= @time_limit_seconds.present? ? '' : 'hidden' %>">
    <p class="text-sm text-amber-900">Drop a pin before time runs out. If time expires, your guess auto-submits.</p>
    <div class="flex items-center gap-2">
      <span class="text-xs text-amber-800">Time left</span>
      <span data-practice-target="timer"
            class="inline-flex min-w-14 justify-center rounded bg-white px-2.5 py-1 text-sm font-semibold text-amber-800 border border-amber-200">
        <%= (@time_limit_seconds || 0) %>s
      </span>
    </div>
    <div class="w-full h-2 rounded-full bg-amber-100 overflow-hidden border border-amber-200/70">
      <div data-practice-target="timerBar"
           class="h-full"
           style="width: 100%"></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Same scroll-zoom + inline-replace-with-original as /games/:id. %>
    <div data-controller="zoomable"
         data-zoomable-cap-width-value="<%= Image::ZOOM_CAP_WIDTH %>"
         class="space-y-1">
      <div data-zoomable-target="viewport"
           class="max-h-[60vh] rounded-md border border-gray-200 overflow-hidden select-none">
        <img src="<%= image_src(@image, width: Image::ZOOM_CAP_WIDTH) %>"
             alt="Guess this location"
             class="max-w-full max-h-[60vh] block mx-auto" />
      </div>
      <div class="flex items-center justify-between gap-2 text-xs text-gray-500">
        <span>scroll to zoom · drag to pan · double-click to reset</span>
        <%# Hidden by default; revealed by zoomable controller only when
            the loaded image was actually downsized (naturalWidth ≥ cap),
            so it never shows up as a no-op. %>
        <% unless @image.photo.attached? %>
          <button type="button"
                  data-zoomable-target="originalButton"
                  data-action="zoomable#loadOriginal"
                  data-zoomable-url-param="<%= image_src(@image) %>"
                  aria-label="Load full quality version of the current image"
                  class="hidden text-gray-500 hover:text-blue-600 underline-offset-2 hover:underline cursor-pointer">
            load full quality
          </button>
        <% end %>
      </div>
    </div>

    <%# Map %>
    <%= render "shared/guess_map" %>
  </div>

  <%# Controls %>
  <div class="flex items-center gap-4">
    <button data-practice-target="guessBtn"
            data-action="practice#submitGuess"
            disabled
            class="btn-primary disabled:opacity-40 disabled:cursor-not-allowed">
      Submit guess
    </button>

    <button data-practice-target="nextBtn"
            data-action="practice#next"
            class="btn-secondary hidden">
      Next image
    </button>

    <p data-practice-target="result" class="text-lg font-medium"></p>

    <%= link_to "View image details", @image,
          target: "_blank",
          aria: { label: "View image details (opens in a new tab)" },
          data: { practice_target: "imageLink" },
          class: "hidden text-blue-600 hover:underline font-medium" %>
  </div>
</div>
