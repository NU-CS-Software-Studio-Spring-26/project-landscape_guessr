<% content_for :title, "AI Image Set" %>

<div class="w-full max-w-2xl mx-auto py-6 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="heading-page">AI Image Set</h1>
    <%= link_to "Cancel", image_sets_path, class: "btn-ghost" %>
  </div>

  <p class="muted">
    Describe the kind of images you want and the AI will build a set for you.
    Try things like "volcanoes in Japan", "castles in Germany", or "lighthouses worldwide".
  </p>

  <%# Conversation thread. We omit the LATEST model turn because the
      result card below renders its explanation in a more prominent way.
      User turns (including the latest) all appear here. %>
  <% if @ai_conversation.any? %>
    <% last_model_idx = @ai_conversation.rindex { |t| t[:role] == "model" } %>
    <section class="card p-4 space-y-3">
      <% @ai_conversation.each_with_index do |turn, i| %>
        <% next if turn[:role] == "model" && i == last_model_idx %>
        <% if turn[:role] == "user" %>
          <div class="text-sm">
            <span class="eyebrow">You</span>
            <p class="mt-1 text-forest-900"><%= turn[:text] %></p>
          </div>
        <% elsif turn[:role] == "model" %>
          <% parsed = (JSON.parse(turn[:text]) rescue {}) %>
          <div class="text-sm">
            <span class="eyebrow">AI</span>
            <p class="mt-1 text-forest-900"><%= parsed["explanation"] %></p>
          </div>
        <% end %>
      <% end %>
    </section>
  <% end %>

  <%# Preview (only when AI gave a non-refusal answer). %>
  <% if @ai_result && !@ai_result[:cannot_answer] %>
    <section class="card p-4 space-y-4">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="eyebrow">Proposed set</p>
          <h2 class="text-xl font-semibold text-forest-900 mt-1"><%= @ai_result[:set_name] %></h2>
        </div>
        <div class="text-right text-sm">
          <% if @ai_count.nil? %>
            <p class="text-amber-700">Couldn't count yet</p>
          <% else %>
            <p><strong class="text-forest-900"><%= number_with_delimiter(@ai_count) %></strong> matching images</p>
            <% if @ai_count > 10_000 %>
              <p class="muted">First 10,000 will be imported</p>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Plain-English explanation from the AI. %>
      <p class="text-sm text-forest-900">
        <span class="eyebrow mr-1">AI</span>
        <%= @ai_result[:explanation] %>
      </p>

      <%# Sample thumbnails. Title shows on hover via both a native
          tooltip (title=) and a gradient overlay. ?width=400 matches the
          show page's image_src(.., width: 400) pattern — covers retina
          density on the ~125-210px CSS cell sizes our grid produces. %>
      <% if @ai_preview && @ai_preview.any? %>
        <div>
          <p class="eyebrow mb-2">Sample (<%= @ai_preview.size %> of <%= @ai_count || "?" %>)</p>
          <div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
            <% @ai_preview.each do |row| %>
              <a href="<%= row[:url] %>" target="_blank" rel="noopener"
                 title="<%= row[:title] %>"
                 class="group relative block aspect-square overflow-hidden rounded-md bg-forest-50 border border-forest-100">
                <img src="<%= row[:url] %>?width=400"
                     alt="<%= row[:title] %>"
                     loading="lazy"
                     class="w-full h-full object-cover transition group-hover:opacity-90" />
                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent text-white text-[11px] leading-tight font-medium px-2 py-2 opacity-0 group-hover:opacity-100 transition-opacity line-clamp-2">
                  <%= row[:title] %>
                </div>
              </a>
            <% end %>
          </div>
        </div>
      <% elsif @ai_count == 0 %>
        <p class="text-sm text-amber-700">
          The AI's query matched 0 images. Try refining your prompt — be more specific
          (e.g. add a country) or use a more common category.
        </p>
      <% end %>

      <%# Image source: only shown if AI chose pageimages, or in advanced expander. %>
      <details class="text-sm">
        <summary class="cursor-pointer text-forest-700 hover:text-forest-900">Image options</summary>
        <div class="mt-3 pl-2 space-y-2">
          <p class="muted">Where should the photos come from?</p>
          <%= form_with url: ai_create_image_sets_path, id: "ai_create_form", local: true, class: "space-y-2" do |f| %>
            <label class="block">
              <input type="radio" name="ai_image_source" value="wikidata_p18" <%= "checked" if @ai_result[:image_source] == "wikidata_p18" %>>
              Wikidata photos (faster, but sometimes older)
            </label>
            <label class="block">
              <input type="radio" name="ai_image_source" value="wikipedia_pageimages" <%= "checked" if @ai_result[:image_source] == "wikipedia_pageimages" %>>
              Wikipedia article photos (fresher; slower import)
            </label>
          <% end %>
        </div>
      </details>

      <%# Advanced: show the actual SPARQL. Closed by default. %>
      <details class="text-sm">
        <summary class="cursor-pointer text-forest-700 hover:text-forest-900">Show query (advanced)</summary>
        <pre class="mt-3 p-3 bg-forest-50 border border-forest-100 rounded-md overflow-x-auto text-xs text-forest-900"><%= @ai_result[:sparql_pattern] %></pre>
      </details>

      <%# Hidden form to import this set. We post directly with the
          AI-generated fields baked into hidden inputs. The radio above
          is moved into this form via the data attribute so it stays in
          one form on submit. %>
      <%= form_with url: ai_create_image_sets_path, local: true, class: "space-y-3 pt-2 border-t border-forest-100" do |f| %>
        <div>
          <label class="text-sm font-medium text-forest-900">Set name</label>
          <%= text_field_tag :name, @ai_result[:set_name], class: "form-input" %>
        </div>
        <div>
          <label class="text-sm font-medium text-forest-900">Visibility</label>
          <%= select_tag :visibility, options_for_select([ ["Private", "private"], ["Public", "public"] ], "private"), class: "form-input select-with-arrow" %>
        </div>
        <%= hidden_field_tag :ai_query, @ai_result[:sparql_pattern] %>
        <%= hidden_field_tag :ai_explanation, @ai_result[:explanation] %>
        <%= hidden_field_tag :ai_prompt, @ai_conversation.find { |t| t[:role] == "user" }&.dig(:text) %>
        <%= hidden_field_tag :ai_model, @model_used.to_s %>
        <%= hidden_field_tag :ai_image_source, @ai_result[:image_source] %>

        <div class="flex justify-end">
          <%= submit_tag "Import images", class: "btn-primary cursor-pointer" %>
        </div>
      <% end %>
    </section>
  <% elsif @ai_result && @ai_result[:cannot_answer] %>
    <section class="card p-4">
      <p class="text-sm text-amber-800"><%= @ai_result[:explanation] %></p>
    </section>
  <% end %>

  <%# Prompt / refinement form. After a turn, this becomes a "refine"
      box; before, it's the initial prompt box.
      data-turbo: false — the action re-renders this page (no redirect),
      which Turbo rejects with "Form responses must redirect to another
      location." A regular form-post + full-page render is the simpler
      fit for this multi-turn flow than wiring up Turbo Streams. %>
  <%= form_with url: ai_generate_image_sets_path, local: true,
        data: { turbo: false, controller: "ai-form-loading", action: "submit->ai-form-loading#submit" },
        class: "space-y-3" do |f| %>
    <div>
      <label class="text-sm font-medium text-forest-900">
        <%= @ai_conversation.any? ? "Refine your request" : "Describe your image set" %>
      </label>
      <%= text_area_tag :user_message, "", class: "form-input", rows: 3,
            placeholder: @ai_conversation.any? ? "e.g. focus only on Hokkaido, or include extinct ones" : "e.g. waterfalls in Norway" %>
    </div>
    <%= hidden_field_tag :conversation_json, @ai_conversation.to_json %>
    <div class="flex justify-end items-center gap-3">
      <span data-ai-form-loading-target="thinking" class="hidden text-sm text-forest-600 italic flex items-center gap-2">
        <svg class="animate-spin h-4 w-4 text-forest-600" viewBox="0 0 24 24" fill="none">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.4 0 0 5.4 0 12h4zm2 5.3A8 8 0 014 12H0c0 3 1.1 5.8 3 8l3-2.7z"></path>
        </svg>
        <span data-thinking-label>Thinking…</span>
      </span>
      <%= submit_tag(@ai_conversation.any? ? "Send" : "Generate",
            class: "btn-primary cursor-pointer",
            data: { ai_form_loading_target: "submit" }) %>
    </div>
  <% end %>
</div>
