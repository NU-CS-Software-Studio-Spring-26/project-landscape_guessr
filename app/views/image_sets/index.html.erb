<% content_for :title, "Image Sets" %>

<div class="w-full max-w-3xl mx-auto space-y-8 py-6">

  <div class="flex items-center justify-between">
    <h1 class="heading-page">Image Sets</h1>
    <div class="flex gap-2">
      <%= link_to "AI set", ai_new_image_sets_path, class: "btn-secondary" %>
      <%= link_to "New set", new_image_set_path, class: "btn-primary" %>
    </div>
  </div>

  <%# My sets %>
  <section class="space-y-3">
    <h2 class="heading-section">My Sets</h2>
    <% if @my_sets.empty? %>
      <p class="text-gray-500 text-sm">You haven't created any sets yet.</p>
    <% else %>
      <% @my_sets.each do |set| %>
        <%= render "image_sets/set_card", set: set, show_owner_actions: true %>
      <% end %>
    <% end %>
  </section>

  <%# Public sets %>
  <section class="space-y-3">
    <h2 class="heading-section">Public Sets</h2>
    <% if @public_sets.empty? %>
      <p class="text-gray-500 text-sm">No public sets yet.</p>
    <% else %>
      <% @public_sets.each do |set| %>
        <%= render "image_sets/set_card", set: set, show_owner_actions: false %>
      <% end %>
    <% end %>
  </section>

</div>
