<% content_for :title, "Leaderboard" %>

<div class="w-full max-w-2xl mx-auto space-y-6 py-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="heading-page">Leaderboard</h1>
      <p class="muted">
        <%= link_to @image_set.name, @image_set, class: "font-medium text-forest-700 hover:text-forest-900" %>
        &middot; Top <%= @games.size %> &middot; highest score over <%= @total_rounds %> rounds
      </p>
    </div>
    <%= link_to "Back to games", games_path, class: "btn-secondary text-sm" %>
  </div>

  <% if @games.any? %>
    <div class="card overflow-hidden">
      <div class="divide-y divide-forest-50">
        <div class="grid grid-cols-[2rem_1fr_6rem] sm:grid-cols-[2rem_1fr_6rem_8rem] gap-4 px-5 py-3 bg-forest-50">
          <span class="eyebrow text-left">#</span>
          <span class="eyebrow">Player</span>
          <span class="eyebrow text-right">Score</span>
          <span class="eyebrow text-right hidden sm:block">Date</span>
        </div>
        <% @games.each_with_index do |game, i| %>
          <div class="grid grid-cols-[2rem_1fr_6rem] sm:grid-cols-[2rem_1fr_6rem_8rem] gap-4 px-5 py-3.5 items-center hover:bg-forest-50 transition-colors">
            <span class="text-sm font-semibold text-gray-400"><%= i + 1 %></span>
            <span class="font-medium text-forest-900 truncate"><%= game.user.username %></span>
            <span class="text-right font-bold text-amber-500 font-display"><%= number_with_delimiter(game.score.to_i) %></span>
            <span class="text-right text-sm text-gray-400 hidden sm:block"><%= local_date_tag(game.completed_at) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="card px-6 py-16 text-center">
      <p class="text-gray-400">No completed games yet — be the first!</p>
    </div>
  <% end %>
</div>
