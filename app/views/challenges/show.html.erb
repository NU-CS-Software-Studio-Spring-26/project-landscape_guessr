<% content_for :title, "Challenge" %>

<div class="w-full max-w-xl mx-auto space-y-6 py-6">

  <div class="space-y-1">
    <p class="eyebrow">Challenge</p>
    <h1 class="heading-page">
      <%= @challenge.image_set&.name || "Default set" %>
    </h1>
    <p class="muted">Created by <%= @challenge.challenger.username %></p>
  </div>

  <%# Share link %>
  <div class="card px-5 py-4 space-y-2 border-forest-200">
    <p class="text-sm font-semibold text-forest-800">Share this link to invite others</p>
    <div class="flex items-center gap-2">
      <code class="flex-1 text-xs bg-forest-50 border border-forest-200 rounded-lg px-3 py-2.5 text-forest-800 truncate select-all font-mono"><%= @share_url %></code>
      <button type="button"
              onclick="navigator.clipboard.writeText('<%= @share_url %>').then(() => { this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy', 1500) })"
              class="btn-secondary text-sm py-2 shrink-0">Copy</button>
    </div>
  </div>

  <%# Play CTA %>
  <% if @my_game.nil? %>
    <%= button_to "Play your game", play_challenge_path(@challenge), method: :post,
          class: "btn-primary w-full py-3 text-base" %>
  <% elsif @my_game.completed_at.nil? %>
    <%= link_to "Continue your game", @my_game, class: "btn-primary w-full py-3 text-base text-center block" %>
  <% end %>

  <%# Results leaderboard %>
  <% if @completed.any? %>
    <section class="space-y-3">
      <h2 class="heading-section">Results</h2>
      <div class="card overflow-hidden divide-y divide-forest-50">
        <% @completed.each_with_index do |game, idx| %>
          <div class="flex items-center gap-4 px-5 py-3.5 bg-white hover:bg-forest-50 transition-colors">
            <span class="text-sm font-semibold text-gray-400 w-5 text-right"><%= idx + 1 %></span>
            <span class="flex-1 font-medium text-forest-900"><%= game.user.username %></span>
            <span class="font-bold text-amber-500 font-display"><%= number_with_delimiter(game.score.to_i) %></span>
            <%= link_to "Results ↗", results_game_path(game),
                  class: "text-xs text-gray-400 hover:text-forest-600 hover:underline underline-offset-2" %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# In progress %>
  <% if @in_progress.any? %>
    <section class="space-y-3">
      <h2 class="heading-section">In progress</h2>
      <div class="card overflow-hidden divide-y divide-forest-50">
        <% @in_progress.each do |game| %>
          <div class="flex items-center gap-4 px-5 py-3.5">
            <span class="flex-1 text-sm text-forest-700"><%= game.user.username %></span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">Playing&hellip;</span>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @completed.empty? && @in_progress.empty? %>
    <div class="card px-6 py-10 text-center">
      <p class="text-gray-400 text-sm">No one has played yet. Share the link above to get started!</p>
    </div>
  <% end %>

  <div class="flex items-center justify-between pt-2">
    <%= link_to "All challenges", challenges_path, class: "btn-ghost" %>
    <% if @challenge.challenger_id == Current.user.id %>
      <%= button_to "Delete challenge", challenge_path(@challenge), method: :delete,
            class: "btn-ghost text-red-500 hover:text-red-700",
            data: { turbo_confirm: "Delete this challenge? This cannot be undone." } %>
    <% end %>
  </div>

</div>
