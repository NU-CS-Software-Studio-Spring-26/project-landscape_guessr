<% content_for :title, "Landscape Guessr" %>

<div class="w-full max-w-md mx-auto text-center space-y-8 py-16">
  <div class="space-y-2">
    <h1 class="text-5xl font-bold">Landscape Guessr</h1>
    <p class="text-lg text-gray-500">Guess the location of natural landmarks around the world.</p>
  </div>

  <div class="flex flex-col gap-3">
    <%= button_to "Start New Game", games_path,
          method: :post,
          class: "rounded-md px-5 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium text-lg cursor-pointer" %>
    <%= link_to "Previous Games", games_path,
          class: "rounded-md px-5 py-3 bg-gray-100 hover:bg-gray-50 font-medium text-lg" %>
    <%= link_to "Practice", practice_path,
          class: "rounded-md px-5 py-3 bg-gray-100 hover:bg-gray-50 font-medium text-lg" %>
  </div>
</div>
