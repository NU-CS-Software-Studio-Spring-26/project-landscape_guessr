<% content_for :title, "Manage Images — #{@image_set.name}" %>

<div class="w-full max-w-4xl mx-auto space-y-8 py-6">

  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="heading-page">Manage Images</h1>
      <p class="muted mt-0.5"><%= @image_set.name %> &middot; <%= @items.size %> image(s)</p>
    </div>
    <%= link_to "Done", @image_set, class: "btn-secondary shrink-0" %>
  </div>

  <%# Bulk upload — primary path. Direct-upload to S3, then a background
      job processes each (HEIC->JPEG, resize, ICC). The page polls for
      processing completion below. %>
  <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 space-y-3">
    <div>
      <h2 class="font-semibold text-gray-700">Upload images</h2>
      <p class="text-xs text-gray-500 mt-0.5">Pick one or many. Coordinates auto-fill from EXIF when present; you can edit them below after the upload.</p>
    </div>
    <%= form_with url: attach_blob_image_set_path(@image_set), method: :post,
                  multipart: true, local: true,
                  data: {
                    controller: "direct-upload",
                    direct_upload_attach_url_value:        attach_blob_image_set_path(@image_set),
                    direct_upload_direct_upload_url_value: rails_direct_uploads_path,
                    direct_upload_redirect_url_value:      locations_image_set_path(@image_set)
                  },
                  class: "flex flex-col sm:flex-row items-start sm:items-end gap-3" do %>
      <div class="flex-1 space-y-1 w-full">
        <%= label_tag "files[]", "Image files", class: "block text-sm font-medium text-gray-700" %>
        <%= file_field_tag "files[]", multiple: true, accept: "image/*",
              class: "block w-full text-sm text-gray-700 file:mr-3 file:rounded-md file:border-0 file:bg-blue-600 file:px-3 file:py-1.5 file:text-white file:font-medium hover:file:bg-blue-500 cursor-pointer" %>
      </div>
      <%= submit_tag "Upload",
            class: "btn-primary shrink-0" %>
    <% end %>
  </div>

  <%# Add-by-URL — secondary path for external images. Collapsed by
      default since most users will just upload files. %>
  <details class="rounded-xl border border-gray-200 bg-white px-5 py-3">
    <summary class="cursor-pointer text-sm font-medium text-gray-700 hover:text-gray-900">
      Add an image by URL
    </summary>
    <div class="pt-3">
      <%= form_with url: add_image_image_set_path(@image_set), method: :post,
                    local: true, class: "grid grid-cols-1 sm:grid-cols-2 gap-3" do %>
        <div class="sm:col-span-2 space-y-1">
          <%= label_tag :url, "Image URL", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :url, nil, placeholder: "https://…",
                class: "form-input mt-0 text-sm" %>
        </div>
        <div class="space-y-1">
          <%= label_tag :title, "Title (optional)", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :title, nil, placeholder: "My Location",
                class: "form-input mt-0 text-sm" %>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div class="space-y-1">
            <%= label_tag :latitude, "Latitude", class: "block text-sm font-medium text-gray-700" %>
            <%= number_field_tag :latitude, nil, step: "any", placeholder: "0.000",
                  class: "form-input mt-0 text-sm" %>
          </div>
          <div class="space-y-1">
            <%= label_tag :longitude, "Longitude", class: "block text-sm font-medium text-gray-700" %>
            <%= number_field_tag :longitude, nil, step: "any", placeholder: "0.000",
                  class: "form-input mt-0 text-sm" %>
          </div>
        </div>
        <div class="sm:col-span-2">
          <%= submit_tag "Add image", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </details>

  <%# Background-processing banner. While any item still has
      data-processing="true", the processing-poll Stimulus controller
      hits processing_status_image_set_path every couple seconds and
      swaps placeholders for real thumbnails as each finishes. No full
      page reload needed. %>
  <% if @processing_count.to_i > 0 %>
    <div id="processing-banner" class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900 flex items-center gap-3">
      <div class="w-4 h-4 rounded-full border-2 border-amber-600 border-t-transparent animate-spin shrink-0"></div>
      <p>Processing <span data-processing-count><%= @processing_count %></span> image(s) in the background — thumbnails will appear here as each finishes.</p>
    </div>
  <% end %>

  <%# Per-item editor: title (delegates to Image), coords (on ImageSetItem),
      remove button. %>
  <% if @items.any? %>
    <%= form_with url: locations_image_set_path(@image_set), method: :put, local: true,
                  class: "space-y-4",
                  data: {
                    controller:                          "processing-poll",
                    processing_poll_url_value:           processing_status_image_set_path(@image_set),
                    processing_poll_banner_id_value:     "processing-banner",
                  } do %>

      <% missing_count = @items.count { |i| (i.latitude || i.image.latitude).blank? || (i.longitude || i.image.longitude).blank? } %>

      <div class="flex items-center justify-between flex-wrap gap-2">
        <h2 class="heading-section">Edit images (<%= @items.size %>)</h2>
        <% if missing_count > 0 %>
          <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1">
            <%= missing_count %> image(s) missing location — set lat/lng below or those images will be skipped when you play this set.
          </p>
        <% end %>
      </div>

      <div class="space-y-3 pb-20">
        <% @items.each do |item| %>
          <% lat = item.latitude || item.image.latitude %>
          <% lng = item.longitude || item.image.longitude %>
          <% missing_loc = lat.blank? || lng.blank? %>
          <div class="rounded-lg border <%= missing_loc ? 'border-amber-300 bg-amber-50/40' : 'border-gray-200 bg-white' %> p-3 flex flex-col sm:flex-row sm:items-center gap-3 group relative"
               data-item-id="<%= item.id %>"
               data-processing="<%= !item.image.processed? %>">

            <%# Thumbnail (or a "processing" placeholder while ProcessImageJob
                converts the freshly-uploaded HEIC) %>
            <% if item.image.processed? %>
              <img src="<%= image_src(item.image, width: 200) %>" alt="<%= item.title %>"
                   class="w-full sm:w-24 h-20 sm:h-16 object-cover rounded-md border border-gray-100 shrink-0">
            <% else %>
              <div class="processing-placeholder w-full sm:w-24 h-20 sm:h-16 rounded-md border border-gray-100 bg-gray-50 flex items-center justify-center text-[10px] text-gray-500 shrink-0 animate-pulse"
                   data-title="<%= item.title %>">
                Processing…
              </div>
            <% end %>

            <%# Title (Image-level) + coordinates (item-level) %>
            <div class="flex-1 min-w-0 space-y-2">
              <div class="space-y-0.5">
                <div class="flex items-center justify-between gap-2">
                  <label class="block text-xs text-gray-500">Title</label>
                  <% if missing_loc %>
                    <span class="text-[10px] font-medium text-amber-700 bg-amber-100 rounded px-1.5 py-0.5">No location</span>
                  <% end %>
                </div>
                <%= text_field_tag "image_set_items[#{item.id}][title]",
                      item.image.title,
                      class: "block w-full rounded border border-gray-300 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
              </div>
              <div class="flex gap-2">
                <div class="flex-1 space-y-0.5">
                  <label class="block text-xs text-gray-500">Latitude</label>
                  <%= number_field_tag "image_set_items[#{item.id}][latitude]",
                        lat&.to_f,
                        step: "any",
                        class: "block w-full rounded border #{missing_loc ? 'border-amber-400' : 'border-gray-300'} px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                </div>
                <div class="flex-1 space-y-0.5">
                  <label class="block text-xs text-gray-500">Longitude</label>
                  <%= number_field_tag "image_set_items[#{item.id}][longitude]",
                        lng&.to_f,
                        step: "any",
                        class: "block w-full rounded border #{missing_loc ? 'border-amber-400' : 'border-gray-300'} px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                </div>
              </div>
            </div>

            <%# Remove — link_to with turbo_method (NOT button_to) because
                we're already inside the bulk-edit form-with above; nesting
                a button_to <form> inside it produces invalid HTML. %>
            <%= link_to "Remove", image_set_remove_item_path(@image_set, item),
                  data: { turbo_method: :delete, turbo_confirm: "Remove “#{item.title}” from this set?" },
                  class: "absolute top-2 right-2 sm:static sm:ml-auto rounded text-xs px-2 py-1 bg-white border border-gray-200 text-gray-500 hover:bg-red-50 hover:text-red-600 cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <%# Sticky save bar — sits at the bottom of the viewport whenever any
          edits have been made and the user is somewhere in the long item
          list. Scrolling past it (e.g. to the page footer) just lets it
          rest in flow. %>
      <div class="sticky bottom-0 bg-white/95 backdrop-blur border-t border-gray-200 -mx-3 px-3 py-3 flex items-center justify-end gap-3 z-40">
        <p class="text-xs text-gray-500 mr-auto">Edits aren't saved until you click Save.</p>
        <%= submit_tag "Save changes", class: "btn-primary" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-sm">Upload some images above to get started.</p>
  <% end %>

</div>
