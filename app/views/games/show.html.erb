<% content_for :title, "Game ##{@game.id}" %>
<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.5.0/dist/maplibre-gl.css" />
  <script src="https://unpkg.com/maplibre-gl@5.5.0/dist/maplibre-gl.js"></script>
<% end %>

<div class="w-full space-y-4">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-3xl">
      <% if @image %>
        Round <%= @round %> / <%= @total_rounds %>
      <% else %>
        Game complete
      <% end %>
    </h1>
    <%= link_to "Back to games", games_path, class: "rounded-md px-3 py-2 bg-gray-100 hover:bg-gray-50 font-medium" %>
  </div>

  <% if @image %>
    <div data-controller="game"
         data-action="guess-map:pinned->game#pinChanged"
         data-game-game-path-value="<%= game_path(@game) %>"
         class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <img src="<%= @image.url %>?width=800" alt="Guess this location"
             class="w-full h-[60vh] object-cover rounded-md border border-gray-200">
      </div>
      <div class="space-y-3">
        <%= render "shared/guess_map" %>
        <%= form_with url: guesses_path, local: true, class: "flex items-center gap-2" do |f| %>
          <%= hidden_field_tag "guess[game_id]", @game.id %>
          <%= hidden_field_tag "guess[image_id]", @image.id %>
          <%= hidden_field_tag "guess[latitude]", "", data: { game_target: "latitude" } %>
          <%= hidden_field_tag "guess[longitude]", "", data: { game_target: "longitude" } %>
          <span data-game-target="readout" class="text-sm text-gray-600">Click the map to drop a pin.</span>
          <p data-game-target="result" class="text-lg font-medium"></p>
          <%= submit_tag "Submit guess", data: { game_target: "submit", action: "game#submitGuess" }, disabled: true,
              class: "ml-auto rounded-md px-3.5 py-2.5 bg-blue-600 text-white font-medium disabled:bg-gray-300 cursor-pointer" %>
          <button type="button" data-game-target="next" data-action="game#nextRound"
                  class="hidden ml-auto rounded-md px-3.5 py-2.5 bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer">
            Next round
          </button>
        <% end %>
      </div>
    </div>
  <% else %>
    <p class="text-lg text-gray-700">You've guessed all <%= @total_rounds %> rounds. Results view coming soon.</p>
    <ul class="text-sm text-gray-600 list-disc pl-5">
      <% @game.guesses.includes(:image).each do |g| %>
        <li><%= g.image.title %> — guessed (<%= g.latitude %>, <%= g.longitude %>)</li>
      <% end %>
    </ul>
  <% end %>
</div>
