<div id="<%= dom_id guess %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Game:</strong>
    <%= guess.game_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Image:</strong>
    <%= guess.image_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Latitude:</strong>
    <%= guess.latitude %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Longitude:</strong>
    <%= guess.longitude %>
  </div>
</div>
