<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) ? "#{content_for(:title)} — Landscape Guessr" : "Landscape Guessr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Landscape Guessr">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans antialiased bg-white text-forest-900 min-h-screen flex flex-col">

    <header class="sticky top-0 z-20 bg-white/95 backdrop-blur-sm border-b border-forest-100 relative"
            data-controller="mobile-menu"
            data-action="keydown.esc@window->mobile-menu#closeOnEscape click@window->mobile-menu#closeOnOutside">
      <%# Desktop + mobile top bar %>
      <nav aria-label="Primary" class="container mx-auto px-5 h-14 flex justify-between items-center">
        <div class="flex items-center gap-6">
          <%= link_to "Landscape Guessr", root_path,
                class: "font-display font-semibold text-forest-800 text-lg tracking-tight hover:text-forest-600 transition-colors" %>
          <%# Desktop nav links %>
          <div class="hidden sm:flex items-center gap-5">
            <% if authenticated? %>
              <%= link_to "Games",       games_path,      class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors" %>
              <%= link_to "Image Sets",  image_sets_path, class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors" %>
              <%= link_to "Challenges",  challenges_path, class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors" %>
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <%# Desktop auth %>
          <div class="hidden sm:flex items-center gap-3">
            <% if authenticated? %>
              <%= link_to Current.user.username, profile_path,
                    class: "text-sm text-forest-700 hover:text-forest-900 font-medium transition-colors" %>
              <%= button_to "Sign out", session_path, method: :delete,
                    class: "btn-secondary text-sm py-1.5 px-3" %>
            <% else %>
              <%= link_to "Sign in",  new_session_path,      class: "btn-secondary text-sm py-1.5 px-3" %>
              <%= link_to "Sign up",  new_registration_path, class: "btn-primary  text-sm py-1.5 px-3" %>
            <% end %>
          </div>

          <%# Mobile hamburger %>
          <button type="button"
                  data-mobile-menu-target="toggleButton"
                  data-action="mobile-menu#toggle"
                  class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-forest-200 bg-white text-forest-700 hover:bg-forest-50 transition-colors cursor-pointer shadow-sm"
                  aria-label="Toggle menu"
                  aria-controls="mobile-primary-menu"
                  aria-expanded="false">
            <span class="text-xs font-semibold uppercase tracking-wide">Menu</span>
            <%# Hamburger icon %>
            <svg data-mobile-menu-target="hamburger" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <%# Close icon (hidden by default) %>
            <svg data-mobile-menu-target="close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </nav>

      <%# Mobile dropdown menu %>
      <div id="mobile-primary-menu"
           data-mobile-menu-target="menu"
           class="hidden absolute right-5 top-[calc(100%+0.5rem)] w-72 max-w-[calc(100vw-2.5rem)] rounded-xl border border-forest-100 bg-white shadow-xl"
           hidden>
        <div class="px-4 py-3 space-y-1">
          <% if authenticated? %>
            <%= link_to "How scoring works", scoring_path, data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <%= link_to "Games",      games_path,      data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <%= link_to "Image Sets", image_sets_path, data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <%= link_to "Challenges", challenges_path, data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <%= link_to "Practice",   practice_path,   data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <div class="pt-3 border-t border-forest-100 flex items-center justify-between">
              <%= link_to Current.user.username, profile_path,
                    data: { action: "mobile-menu#close" },
                    class: "text-sm text-forest-600 font-medium" %>
              <%= button_to "Sign out", session_path, method: :delete,
                    class: "btn-secondary text-sm py-1.5 px-3" %>
            </div>
          <% else %>
            <%= link_to "Sign in",  new_session_path,      data: { action: "mobile-menu#close" }, class: "btn-primary w-full text-center block" %>
            <%= link_to "Practice", practice_path,         data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <%= link_to "How scoring works", scoring_path, data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <%= link_to "About",    about_path,            data: { action: "mobile-menu#close" }, class: "block py-2.5 text-sm font-medium text-forest-800 hover:text-forest-600 transition-colors" %>
            <div class="pt-3">
              <%= link_to "Sign up free", new_registration_path, class: "btn-primary w-full text-center block" %>
            </div>
          <% end %>
        </div>
      </div>
    </header>

    <main aria-label="Main content" class="container mx-auto px-4 sm:px-5 py-6 sm:py-8 flex-1">
      <% if notice = flash[:notice] %>
        <div class="mb-6 py-3 px-4 bg-forest-50 text-forest-700 font-medium rounded-xl border border-forest-200 flex items-center gap-2 text-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-forest-500 shrink-0"></span>
          <%= notice %>
        </div>
      <% end %>
      <% if alert = flash[:alert] %>
        <div class="mb-6 py-3 px-4 bg-red-50 text-red-700 font-medium rounded-xl border border-red-200 flex items-center gap-2 text-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500 shrink-0"></span>
          <%= alert %>
        </div>
      <% end %>
      <% if authenticated? && !Current.user.email_verified? %>
        <% if flash[:verify_email] %>
          <div class="py-2 px-3 mb-5 bg-red-50 text-red-700 font-medium rounded-md mx-auto md:w-2/3 w-full flex justify-between items-center">
            <span>Please verify your email to access this feature.</span>
            <%= button_to "Resend verification", email_verification_path, method: :post, class: "text-red-800 underline hover:no-underline text-sm" %>
          </div>
        <% else %>
          <div class="py-2 px-3 mb-5 bg-yellow-50 text-yellow-800 font-medium rounded-md mx-auto md:w-2/3 w-full flex justify-between items-center">
            <span>Check your inbox and verify your email to unlock all features.</span>
            <%= button_to "Resend", email_verification_path, method: :post, class: "text-yellow-900 underline hover:no-underline text-sm" %>
          </div>
        <% end %>
      <% end %>
      <%= yield %>
    </main>

    <footer class="bg-forest-50 border-t border-forest-100 mt-auto">
      <div class="container mx-auto px-4 sm:px-5 py-6 text-xs text-forest-700 flex flex-wrap items-center justify-between gap-3">
        <span class="font-medium">Landscape Guessr &middot; <%= Date.current.year %></span>
        <span class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <%= link_to "About",  about_path, class: "hover:text-forest-900 transition-colors" %>
          <%= link_to "Legal",  legal_path, class: "hover:text-forest-900 transition-colors" %>
          <%= link_to "GitHub", "https://github.com/NU-CS-Software-Studio-Spring-26/project-landscape_guessr",
                class: "hover:text-forest-900 transition-colors" %>
          <span class="text-forest-400 hidden sm:inline">Built for CS-397 with Rails 8</span>
        </span>
      </div>
    </footer>

  </body>
</html>
