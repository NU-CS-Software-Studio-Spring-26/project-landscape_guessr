<% content_for :title, "New Challenge" %>

<div class="min-h-[calc(100vh-12rem)] flex items-center justify-center py-12">
  <div class="w-full max-w-sm space-y-6">
    <div class="text-center space-y-1">
      <p class="eyebrow">Multiplayer</p>
      <h1 class="heading-page">Create a challenge</h1>
      <p class="muted">Pick an image set, share the link, and see who scores higher.</p>
    </div>

    <div class="card p-8 space-y-5">
      <%= form_with url: challenges_path, method: :post do |f| %>
        <div>
          <%= f.label :image_set_id, "Image set", class: "block text-sm font-medium text-forest-800" %>
          <%= f.select :image_set_id,
                @image_sets.map { |s| [ s.name + (s.is_system_default? ? " (default)" : ""), s.id ] },
                { include_blank: false },
                class: "form-input select-with-arrow pr-8" %>
          <p class="muted text-xs mt-1.5">Everyone who joins draws randomly from this set.</p>
        </div>
        <%= f.submit "Create challenge", class: "btn-primary w-full" %>
      <% end %>
    </div>

    <%= link_to "Back to challenges", challenges_path, class: "block text-center btn-ghost" %>
  </div>
</div>
