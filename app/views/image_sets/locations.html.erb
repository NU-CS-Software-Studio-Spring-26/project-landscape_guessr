<% content_for :title, "Edit Locations — #{@image_set.name}" %>

<div class="w-full max-w-4xl mx-auto space-y-8 py-6">

  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="heading-page">Edit Locations</h1>
      <p class="muted mt-0.5"><%= @image_set.name %></p>
    </div>
    <%= link_to "Back to set", @image_set, class: "btn-secondary shrink-0" %>
  </div>

  <%# Add image panel — tabbed: Upload file / Enter URL %>
  <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 space-y-4"
       data-controller="add-image-tabs">

    <h2 class="font-semibold text-gray-700">Add an Image</h2>

    <%# Tab buttons %>
    <div class="flex gap-1 rounded-lg bg-gray-200 p-1 w-fit">
      <button type="button"
              data-action="add-image-tabs#showUpload"
              data-add-image-tabs-target="uploadTab"
              class="rounded-md px-4 py-1.5 text-sm font-medium transition-colors bg-white shadow text-gray-900">
        Upload file
      </button>
      <button type="button"
              data-action="add-image-tabs#showUrl"
              data-add-image-tabs-target="urlTab"
              class="rounded-md px-4 py-1.5 text-sm font-medium transition-colors text-gray-600 hover:text-gray-900">
        Enter URL
      </button>
    </div>

    <%# Upload file form %>
    <div data-add-image-tabs-target="uploadPanel">
      <%= form_with url: add_image_image_set_path(@image_set), method: :post,
                    multipart: true, local: true,
                    data: { controller: "upload-progress" },
                    class: "grid grid-cols-1 sm:grid-cols-2 gap-3" do %>
        <div class="sm:col-span-2 space-y-1">
          <%= label_tag :file, "Image file", class: "block text-sm font-medium text-gray-700" %>
          <%= file_field_tag :file, accept: "image/*",
                class: "block w-full text-sm text-gray-700 file:mr-3 file:rounded-md file:border-0 file:bg-blue-600 file:px-3 file:py-1.5 file:text-white file:font-medium hover:file:bg-blue-500 cursor-pointer" %>
        </div>
        <div class="space-y-1">
          <%= label_tag :title, "Title (optional — defaults to filename)", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :title, nil, placeholder: "My Location",
                class: "form-input mt-0 text-sm" %>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div class="space-y-1">
            <%= label_tag :latitude, "Latitude", class: "block text-sm font-medium text-gray-700" %>
            <%= number_field_tag :latitude, nil, step: "any", placeholder: "0.000",
                  class: "form-input mt-0 text-sm" %>
          </div>
          <div class="space-y-1">
            <%= label_tag :longitude, "Longitude", class: "block text-sm font-medium text-gray-700" %>
            <%= number_field_tag :longitude, nil, step: "any", placeholder: "0.000",
                  class: "form-input mt-0 text-sm" %>
          </div>
        </div>
        <div class="sm:col-span-2">
          <%= submit_tag "Add image", class: "btn-primary" %>
        </div>
      <% end %>
    </div>

    <%# Enter URL form %>
    <div data-add-image-tabs-target="urlPanel" class="hidden">
      <%= form_with url: add_image_image_set_path(@image_set), method: :post,
                    local: true, class: "grid grid-cols-1 sm:grid-cols-2 gap-3" do %>
        <div class="sm:col-span-2 space-y-1">
          <%= label_tag :url, "Image URL", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :url, nil, placeholder: "https://…",
                class: "form-input mt-0 text-sm" %>
        </div>
        <div class="space-y-1">
          <%= label_tag :title, "Title (optional)", class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag :title, nil, placeholder: "My Location",
                class: "form-input mt-0 text-sm" %>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div class="space-y-1">
            <%= label_tag :latitude, "Latitude", class: "block text-sm font-medium text-gray-700" %>
            <%= number_field_tag :latitude, nil, step: "any", placeholder: "0.000",
                  class: "form-input mt-0 text-sm" %>
          </div>
          <div class="space-y-1">
            <%= label_tag :longitude, "Longitude", class: "block text-sm font-medium text-gray-700" %>
            <%= number_field_tag :longitude, nil, step: "any", placeholder: "0.000",
                  class: "form-input mt-0 text-sm" %>
          </div>
        </div>
        <div class="sm:col-span-2">
          <%= submit_tag "Add image", class: "btn-primary" %>
        </div>
      <% end %>
    </div>

  </div>

  <%# Bulk upload panel — direct-upload to S3, then a background job
      processes each (HEIC->JPEG, resize, ICC). The form submit only
      carries blob signed-ids, so it returns instantly even for large
      batches. See ProcessImageJob. %>
  <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 space-y-3">
    <div>
      <h2 class="font-semibold text-gray-700">Bulk Upload</h2>
      <p class="text-xs text-gray-500 mt-0.5">Select multiple image files at once. Coordinates auto-fill from EXIF when present.</p>
    </div>
    <%= form_with url: attach_blob_image_set_path(@image_set), method: :post,
                  multipart: true, local: true,
                  data: {
                    controller: "direct-upload",
                    direct_upload_attach_url_value:        attach_blob_image_set_path(@image_set),
                    direct_upload_direct_upload_url_value: rails_direct_uploads_path,
                    direct_upload_redirect_url_value:      locations_image_set_path(@image_set)
                  },
                  class: "flex flex-col sm:flex-row items-start sm:items-end gap-3" do %>
      <div class="flex-1 space-y-1 w-full">
        <%= label_tag "files[]", "Image files", class: "block text-sm font-medium text-gray-700" %>
        <%= file_field_tag "files[]", multiple: true, accept: "image/*",
              class: "block w-full text-sm text-gray-700 file:mr-3 file:rounded-md file:border-0 file:bg-blue-600 file:px-3 file:py-1.5 file:text-white file:font-medium hover:file:bg-blue-500 cursor-pointer" %>
      </div>
      <%= submit_tag "Upload all",
            class: "btn-primary shrink-0" %>
    <% end %>
  </div>

  <%# Background-processing banner. While any item still has
      data-processing="true", the processing-poll Stimulus controller
      hits processing_status_image_set_path every couple seconds and
      swaps placeholders for real thumbnails as each finishes. No full
      page reload needed. %>
  <% if @processing_count.to_i > 0 %>
    <div id="processing-banner" class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900 flex items-center gap-3">
      <div class="w-4 h-4 rounded-full border-2 border-amber-600 border-t-transparent animate-spin shrink-0"></div>
      <p>Processing <span data-processing-count><%= @processing_count %></span> image(s) in the background — thumbnails will appear here as each finishes.</p>
    </div>
  <% end %>

  <%# Batch location editor %>
  <% if @items.any? %>
    <%= form_with url: locations_image_set_path(@image_set), method: :put, local: true,
                  class: "space-y-4",
                  data: {
                    controller:                          "processing-poll",
                    processing_poll_url_value:           processing_status_image_set_path(@image_set),
                    processing_poll_banner_id_value:     "processing-banner",
                  } do %>

      <div class="space-y-3">
        <% @items.each do |item| %>
          <div class="rounded-lg border border-gray-200 bg-white p-3 flex flex-col sm:flex-row sm:items-center gap-3"
               data-item-id="<%= item.id %>"
               data-processing="<%= !item.image.processed? %>">

            <%# Thumbnail (or a "processing" placeholder while ProcessImageJob
                converts the freshly-uploaded HEIC) %>
            <% if item.image.processed? %>
              <img src="<%= image_src(item.image, width: 200) %>" alt="<%= item.title %>"
                   class="w-full sm:w-24 h-20 sm:h-16 object-cover rounded-md border border-gray-100 shrink-0">
            <% else %>
              <div class="processing-placeholder w-full sm:w-24 h-20 sm:h-16 rounded-md border border-gray-100 bg-gray-50 flex items-center justify-center text-[10px] text-gray-500 shrink-0 animate-pulse"
                   data-title="<%= item.title %>">
                Processing…
              </div>
            <% end %>

            <%# Title + coordinates %>
            <div class="flex-1 min-w-0 space-y-2">
              <p class="text-sm font-medium text-gray-800 truncate"><%= item.title %></p>
              <div class="flex gap-2">
                <div class="flex-1 space-y-0.5">
                  <label class="block text-xs text-gray-500">Latitude</label>
                  <%= number_field_tag "image_set_items[#{item.id}][latitude]",
                        (item.latitude || item.image.latitude)&.to_f,
                        step: "any",
                        class: "block w-full rounded border border-gray-300 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                </div>
                <div class="flex-1 space-y-0.5">
                  <label class="block text-xs text-gray-500">Longitude</label>
                  <%= number_field_tag "image_set_items[#{item.id}][longitude]",
                        (item.longitude || item.image.longitude)&.to_f,
                        step: "any",
                        class: "block w-full rounded border border-gray-300 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <%= submit_tag "Save all locations", class: "btn-primary" %>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-sm">Add images above to start editing locations.</p>
  <% end %>

</div>
