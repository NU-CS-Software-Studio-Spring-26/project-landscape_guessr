<% content_for :title, "Results — Game ##{@game.id}" %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview">
<% end %>

<div class="w-full max-w-2xl mx-auto space-y-6 py-6"
     data-controller="results-map"
     data-results-map-style-value="<%= @game.image_set&.map_style || 'outdoor-v2' %>"
     data-results-map-rounds-value="<%= @map_rounds.to_json %>"
     data-results-map-players-value="<%= (@challenge_players || []).to_json %>">

  <%# Header %>
  <div class="text-center space-y-1">
    <p class="eyebrow">Game complete</p>
    <h1 class="heading-page">Here's how you did</h1>
  </div>

  <% if @new_personal_best %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3"
         data-controller="confetti"
         data-confetti-colors-value='["#3b82f6","#22c55e","#f59e0b","#ef4444","#a855f7"]'>
      <p class="text-sm font-semibold text-amber-900">New personal best!</p>
      <% if @previous_best_score.present? %>
        <p class="text-xs text-amber-800 mt-0.5">
          You beat your previous best of <%= number_with_delimiter(@previous_best_score.round) %> by
          <%= number_with_delimiter(@personal_best_delta.round) %> points.
        </p>
      <% else %>
        <p class="text-xs text-amber-800 mt-0.5">This is your first completed score on record.</p>
      <% end %>
    </div>
  <% end %>

  <%# Total score card %>
  <div class="card px-6 py-8 text-center space-y-1">
    <p class="eyebrow">Total Score</p>
    <p class="text-6xl font-bold font-display text-amber-500"><%= number_with_delimiter(@score.to_i) %></p>
    <p class="text-sm text-gray-400">
      out of <%= number_with_delimiter(@total_rounds * Game::GEOGUESSR_MAX_ROUND_SCORE) %>
      &middot; total distance <%= format_distance_compact(@total_distance_km) %>
    </p>
  </div>

  <%# Summary map %>
  <div class="card overflow-hidden">
    <div class="px-4 py-2.5 border-b border-forest-100 bg-forest-50 flex items-center gap-2">
      <span class="eyebrow">Map</span>
      <span class="text-xs text-gray-400">&mdash;</span>
      <span class="flex items-center gap-3 text-xs text-gray-500">
        <span class="flex items-center gap-1"><span class="inline-block w-2.5 h-2.5 rounded-full bg-red-400"></span> your guess</span>
        <span class="flex items-center gap-1"><span class="inline-block w-2.5 h-2.5 rounded-full bg-forest-500"></span> actual location</span>
      </span>
      <span class="ml-auto text-xs text-gray-400">click a round to focus</span>
    </div>
    <div data-results-map-target="container" class="w-full h-72"></div>
  </div>

  <%# Round breakdown %>
  <section class="space-y-3">
    <h2 class="heading-section">Round Breakdown</h2>
    <% @rounds.each_with_index do |row, idx| %>
      <div data-action="click->results-map#focus"
           data-results-map-round-param="<%= idx + 1 %>"
           class="card hover:border-forest-200 transition-colors cursor-pointer px-4 py-3 flex flex-col sm:flex-row sm:items-center gap-3">
        <% thumb = image_src(row[:guess].image, width: 200) %>
        <% if thumb %>
          <img src="<%= thumb %>" alt="<%= row[:guess].image.title.presence || 'Landscape image' %>"
               loading="lazy"
               class="shrink-0 w-full sm:w-24 h-20 sm:h-16 object-cover rounded-lg border border-forest-100">
        <% end %>
        <div class="flex-1 min-w-0">
          <span class="eyebrow">Round <%= idx + 1 %></span>
          <p class="font-medium text-forest-900 truncate"><%= row[:guess].image.title %></p>
        </div>
        <div class="flex gap-4 sm:text-right shrink-0">
          <div>
            <p class="text-xs text-gray-400">Score</p>
            <p class="font-bold text-amber-500"><%= number_with_delimiter(row[:round_score]) %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400">Distance</p>
            <p class="font-medium text-forest-700"><%= format_distance_compact(row[:distance_km]) %></p>
          </div>
        </div>
        <%= link_to "Details ↗", row[:guess].image,
              class: "shrink-0 self-end sm:self-auto px-2 py-1.5 text-xs text-gray-400 hover:text-forest-600 hover:underline underline-offset-2" %>
      </div>
    <% end %>
  </section>

  <%# Challenge leaderboard %>
  <% if @challenge_games&.any? %>
    <section class="space-y-3">
      <h2 class="heading-section">Challenge leaderboard</h2>
      <div class="card overflow-hidden divide-y divide-forest-50">
        <% @challenge_games.each_with_index do |g, idx| %>
          <div class="flex items-center gap-4 px-5 py-3 <%= g.id == @game.id ? "bg-forest-50" : "bg-white" %>">
            <span class="text-sm font-semibold text-gray-400 w-5 text-right"><%= idx + 1 %></span>
            <span class="flex-1 font-medium text-forest-900">
              <%= g.user.username %>
              <% if g.id == @game.id %>
                <span class="text-xs text-forest-500 ml-1 font-normal">you</span>
              <% end %>
            </span>
            <span class="font-bold text-amber-500"><%= number_with_delimiter(g.score.to_i) %></span>
          </div>
        <% end %>
      </div>
      <%= link_to "View challenge", @game.challenge,
            class: "text-sm text-forest-600 hover:text-forest-800 hover:underline underline-offset-2" %>
    </section>
  <% end %>

  <%# Action buttons %>
  <div class="flex gap-3 pt-2 flex-wrap">
    <%= button_to "Play Again", games_path, method: :post,
          params: { image_set_id: @game.image_set_id },
          class: "btn-primary flex-1" %>
    <%= link_to "Leaderboard", leaderboard_games_path(image_set_id: @game.image_set_id),
          class: "btn-secondary flex-1" %>
    <% if @game.challenge %>
      <%= link_to "View challenge", @game.challenge, class: "btn-secondary flex-1" %>
    <% else %>
      <%= link_to "All games", games_path, class: "btn-secondary flex-1" %>
    <% end %>
  </div>

</div>
