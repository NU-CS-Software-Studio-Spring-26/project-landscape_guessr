<% content_for :title, "#{@image_set.name} — Map" %>
<% content_for :head do %>
  <%= render "shared/maplibre_assets" %>
<% end %>

<div class="w-full max-w-5xl mx-auto space-y-4 py-6">
  <div class="flex justify-between items-center gap-4">
    <div>
      <h1 class="heading-page"><%= @image_set.name %> — Map</h1>
      <p class="muted mt-0.5"><%= @image_data.size %> located image(s)</p>
    </div>
    <%= link_to "Back to set", @image_set, class: "btn-secondary shrink-0" %>
  </div>

  <% if @image_data.empty? %>
    <p class="text-gray-500 text-sm">None of the images in this set have coordinates yet.</p>
  <% else %>
    <%= render "shared/image_map", points: @image_data, element_id: "image-set-map" %>
  <% end %>
</div>
