<%#
  Shared world map with one circle per point.
  Used by /images/map and /image_sets/:id/map.

  Locals:
    points       — array of { id:, lat:, lng:, title:, url: } hashes
    element_id   — DOM id for the map container (default "image-map")
    height_class — Tailwind height class (default "h-[80vh]")
    style        — MapTiler style slug (default "outdoor-v2")

  The image-map Stimulus controller loads the MapTiler SDK on connect,
  so the page doesn't need to inject any map assets in <head>.
%>
<% element_id   ||= "image-map" %>
<% height_class ||= "h-[80vh]" %>
<% style       ||= "outdoor-v2" %>

<div id="<%= element_id %>"
     class="w-full <%= height_class %> rounded-md border border-gray-200 overflow-hidden"
     data-controller="image-map"
     data-image-map-style-value="<%= style %>"
     data-image-map-points-value="<%= points.to_json %>"></div>
