<% content_for :title, "Challenge" %>

<div class="w-full max-w-xl mx-auto space-y-6 py-6">

  <div class="space-y-1">
    <h1 class="heading-page">Challenge</h1>
    <p class="muted">
      Created by <%= @challenge.challenger.username %>
      <% if @challenge.image_set %>
        &middot; <%= @challenge.image_set.name %>
      <% end %>
    </p>
  </div>

  <%# Share link %>
  <div class="rounded-xl border border-blue-200 bg-blue-50 px-5 py-4 space-y-2">
    <p class="text-sm font-medium text-blue-800">Share this link to invite others</p>
    <div class="flex items-center gap-2">
      <code class="flex-1 text-sm bg-white border border-blue-200 rounded-md px-3 py-2 text-blue-900 truncate select-all"><%= @share_url %></code>
      <button type="button"
              onclick="navigator.clipboard.writeText('<%= @share_url %>').then(() => { this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy', 1500) })"
              class="btn-secondary text-sm py-2 shrink-0">Copy</button>
    </div>
  </div>

  <%# Play button — only if current user hasn't played %>
  <% if @my_game.nil? %>
    <%= button_to "Play your game", play_challenge_path(@challenge), method: :post,
          class: "btn-primary w-full" %>
  <% elsif @my_game.completed_at.nil? %>
    <%= link_to "Continue your game", @my_game, class: "btn-primary w-full text-center block" %>
  <% end %>

  <%# Leaderboard — completed games %>
  <% if @completed.any? %>
    <section class="space-y-3">
      <h2 class="heading-section">Results</h2>
      <div class="divide-y divide-gray-100 border border-gray-200 rounded-lg overflow-hidden">
        <% @completed.each_with_index do |game, idx| %>
          <div class="flex items-center gap-4 px-4 py-3 bg-white">
            <span class="text-sm font-medium text-gray-400 w-5 text-right"><%= idx + 1 %></span>
            <span class="flex-1 font-medium text-gray-800"><%= game.user.username %></span>
            <span class="font-semibold text-blue-600"><%= number_with_delimiter(game.score.to_i) %></span>
            <%= link_to "Results", results_game_path(game), class: "text-xs text-gray-400 hover:text-blue-600 hover:underline" %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# In-progress players %>
  <% if @in_progress.any? %>
    <section class="space-y-2">
      <h2 class="heading-section">In progress</h2>
      <div class="divide-y divide-gray-100 border border-gray-200 rounded-lg overflow-hidden">
        <% @in_progress.each do |game| %>
          <div class="flex items-center gap-4 px-4 py-3 bg-white">
            <span class="flex-1 text-sm text-gray-600"><%= game.user.username %></span>
            <span class="text-xs text-gray-400">Playing&hellip;</span>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @completed.empty? && @in_progress.empty? %>
    <p class="muted text-center py-4">No one has played yet. Share the link above to get started!</p>
  <% end %>

  <div class="flex items-center justify-between pt-2">
    <%= link_to "All challenges", challenges_path, class: "btn-ghost" %>
    <% if @challenge.challenger_id == Current.user.id %>
      <%= button_to "Delete challenge", challenge_path(@challenge), method: :delete,
            class: "btn-ghost text-red-500 hover:text-red-700",
            data: { turbo_confirm: "Delete this challenge? This cannot be undone." } %>
    <% end %>
  </div>
</div>
