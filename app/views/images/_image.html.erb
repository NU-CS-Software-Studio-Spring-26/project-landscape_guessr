<div id="<%= dom_id image %>" class="w-full sm:w-auto my-5 space-y-3">
  <%= image_tag "#{image.url}?width=400", loading: "lazy", class: "w-64 h-40 object-cover rounded-md bg-gray-100", alt: image.title %>
  <div class="text-sm">
    <div><strong>Title:</strong> <%= image.title %></div>
    <div><strong>Lat:</strong> <%= image.latitude %>, <strong>Lng:</strong> <%= image.longitude %></div>
    <div class="truncate max-w-xs"><strong>Url:</strong> <%= link_to image.url, image.url, target: "_blank", class: "text-blue-600 hover:underline" %></div>
  </div>
</div>
